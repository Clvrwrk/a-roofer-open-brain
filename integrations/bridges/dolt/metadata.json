{
  "name": "dolt-resource",
  "display_name": "Dolt",
  "version": "1.0.0-kb",
  "tier": "infrastructure-data-versioning-lab",
  "source_system_type": "version-controlled-sql-database",
  "enabled": true,
  "origin": "cleverwork",
  "bound_agents": ["innovator", "quality-control", "auditor", "maintenance"],
  "env_vars": {
    "required": [],
    "optional": ["DOLT_REMOTE_URL", "DOLT_USER", "DOLT_EMAIL"]
  },
  "api_docs": "https://www.dolthub.com/docs/introduction/what-is-dolt/",
  "objects_governed": ["repositories", "tables", "branches", "commits", "diffs", "pull_requests"],
  "notes": "Enabled as a lab resource only. Dolt CLI/auth are configured for non-sensitive data-diff pilots and must not replace Supabase/Postgres for the live brain."
}
