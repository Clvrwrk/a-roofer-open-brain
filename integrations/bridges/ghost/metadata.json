{
  "name": "ghost-resource",
  "display_name": "Ghost",
  "version": "1.0.0-kb",
  "tier": "infrastructure-postgres-lab",
  "source_system_type": "agent-database-lab",
  "enabled": true,
  "origin": "cleverwork",
  "bound_agents": ["innovator", "maintenance", "auditor", "quality-control"],
  "env_vars": {
    "required": [],
    "optional": ["GHOST_API_KEY", "GHOST_SPACE_ID", "GHOST_DEFAULT_DATABASE"]
  },
  "api_docs": "https://ghost.build/docs/#introduction",
  "objects_governed": ["databases", "forks", "schemas", "sql_queries", "logs", "restore_drills"],
  "notes": "Enabled as a lab resource only. Ghost CLI, OAuth, MCP, and a lab database are configured; production data remains in Supabase."
}
