{
  "name": "acculynx-bridge",
  "display_name": "AccuLynx",
  "version": "1.0.0",
  "tier": 1,
  "source_system_type": "saas-with-api",
  "enabled": false,
  "origin": "cleverwork",
  "bound_agents": ["capture", "conductor"],
  "env_vars": {
    "required": ["ACCULYNX_API_KEY", "ACCULYNX_WEBHOOK_SECRET"],
    "optional": ["ACCULYNX_PULL_SCHEDULE_MINUTES"]
  },
  "webhook_topics": [
    "job_created",
    "job_updated",
    "job.milestone.current_changed",
    "job.milestone.status.current_changed",
    "job.category_changed",
    "job.trade-type_changed",
    "job.work-type_changed",
    "job.financials.approved-value_changed",
    "invoice_updated",
    "invoice_voided",
    "contact_added",
    "contact_changed",
    "job.primary-contact_changed",
    "job.representatives.company_assigned",
    "job.representatives.company_changed",
    "job.appointments.initial_created",
    "job.appointments.initial_updated"
  ],
  "objects_ingested": [
    "jobs",
    "milestones",
    "contacts",
    "insurance",
    "adjuster",
    "supplements",
    "estimates",
    "financials",
    "invoices",
    "payments",
    "photos_videos",
    "messages",
    "representatives"
  ],
  "job_phase_map": {
    "Lead": "lead",
    "Appointment Set": "lead",
    "Inspection Complete": "estimate",
    "Estimate Sent": "estimate",
    "Approved": "won",
    "Contract Signed": "won",
    "Material Ordered": "in_progress",
    "In Production": "in_progress",
    "Job Complete": "punch",
    "Final Inspection": "punch",
    "Invoice Sent": "closed",
    "Final Payment Received": "closed",
    "Warranty": "warranty",
    "Lost": "lost",
    "Dead": "lost"
  },
  "debrief_trigger_milestone": ["closed", "warranty"],
  "api_base_url": "https://api.acculynx.com/api/v2",
  "api_docs": "https://apidocs.acculynx.com/reference/",
  "notes": "Milestone names in job_phase_map must match the AccuLynx account exactly (case-sensitive). Override via config/roofer.config.yaml → integrations.acculynx.milestone_map."
}
