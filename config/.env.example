# ──────────────────────────────────────────────────────────────────────────
# a-roofers-open-brain — secrets (NAMES ONLY; never commit real values)
# If starting from scratch, copy this template to repo-root .env and fill in.
# Never copy real .env values back into this template.
# In production, runtime secrets live in Coolify app env (or a vault), not on a laptop.
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase (the brain) ---
# Current Pro Exteriors instance: https://rnhmvcpsvtqjlffpsayu.supabase.co
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__set_me__          # service_role; used by the internal brain-mcp container only
SUPABASE_ANON_KEY=__set_me__                  # server-side/dashboard read path
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=__set_me__           # public dashboard read path (anon key only)
SUPABASE_PROJECT_REF=__set_me__
SUPABASE_ACCESS_TOKEN=__set_me__              # optional CLI/management automation token; prefer local supabase login
SUPABASE_MCP_URL=https://mcp.supabase.com/mcp?project_ref=YOUR-PROJECT
SUPABASE_DB_PASSWORD=__set_me__
# Full Postgres connection string — used by scripts/new-client.sh + verify-deployment.sh to apply migrations
SUPABASE_DB_URL=postgresql://postgres:__db_password__@db.YOUR-PROJECT.supabase.co:5432/postgres
SUPABASE_ORG_ID=__set_me__                    # only needed if new-client.sh creates the project

# --- Open Brain MCP access (per-container access keys; one per runtime boundary) ---
OB_ACCESS_KEY_HISTORIAN=__set_me__            # internal retrieval/write container
OB_ACCESS_KEY_RESEARCHER=__set_me__           # external retrieval container (separate creds!)
OB_ACCESS_KEY_CAPTURE=__set_me__

# --- Runtime URLs (Coolify containers; full HTTPS endpoints) ---
BRAIN_MCP_URL=https://brain-mcp.CLIENT.brain.cleverwork.io
RESEARCHER_MCP_URL=https://researcher.CLIENT.brain.cleverwork.io
ACCULYNX_BRIDGE_URL=https://acculynx.CLIENT.brain.cleverwork.io
DASHBOARD_URL=https://CLIENT.brain.cleverwork.io
COMMAND_CENTER_PUBLIC_URL=https://cc.proexteriorsus.net
COMMAND_CENTER_AUTH_MODE=disabled             # disabled | workos

# --- Coolify deploy hooks (optional; used by scripts/new-client.sh) ---
# Use the per-resource Deploy Webhook URL from Coolify. If the hook requires
# auth, set COOLIFY_API_TOKEN with deploy-only permissions.
COOLIFY_API_TOKEN=__set_me__
COOLIFY_BRAIN_MCP_DEPLOY_HOOK=__set_me__
COOLIFY_RESEARCHER_DEPLOY_HOOK=__set_me__
COOLIFY_ACCULYNX_BRIDGE_DEPLOY_HOOK=__set_me__
COOLIFY_DASHBOARD_DEPLOY_HOOK=__set_me__

# --- Kasm Workspaces admin API (headless user + session creation) ---
# WHERE: https://desktops.proexteriorsus.net → log in as admin@kasm.local (NOT your GW password)
#        Admin pw is in /root/hermes-dashboard-credentials.txt on agent host (ssh in to read it)
#        → Admin panel (/#/admin) → Access Management → API Configs → Add Config → Generate
# ⚠️  AFTER GENERATING: new API keys have ZERO permissions by default. Run this once on agent host:
#   docker exec kasm_db psql -U kasmapp -d kasm -c "INSERT INTO group_permissions
#   (permission_id, group_id, api_id) VALUES (200,
#   (SELECT group_id FROM groups WHERE name='Administrators'),
#   (SELECT api_id FROM api_configs WHERE name='hermes-automation'));"
# ⚠️  API PATH is /api/admin/<endpoint> — NOT /api/v2/ (that returns 404)
KASM_API_BASE=https://desktops.proexteriorsus.net
KASM_API_KEY=__set_me__
KASM_API_KEY_SECRET=__set_me__

# --- Slack app configuration token (headless app creation via Manifest API) ---
# WHERE: https://api.slack.com/authentication/config-tokens → Generate Token for pe-command-center
# ⚠️  This is an ACCOUNT-LEVEL config token (xoxe.xoxp-...) — NOT an app-level token (xapp-)
#     The xapp- token from inside an app is for Socket Mode only — it returns "not_allowed_token_type"
#     on any Manifest API call. Go directly to the /authentication/config-tokens URL above.
# ⚠️  SAVE BOTH TOKENS — access token expires; refresh token (xoxe-1-) is used to renew it
#     Renewal: POST https://slack.com/api/tooling.tokens.rotate with refresh_token
SLACK_APP_CONFIG_TOKEN=__set_me__           # xoxe.xoxp-... (~183 chars) — expires periodically
SLACK_APP_CONFIG_REFRESH_TOKEN=__set_me__  # xoxe-1-... (~158 chars) — use to renew access token
SLACK_TEAM_ID=T0B8QEGPVQW

# --- Google Cloud (headless SA creation + API enablement) ---
# ⚠️  TWO separate auth commands are required — each authorizes a different path:
#   gcloud auth login                          ← authorizes gcloud CLI tools
#   gcloud auth application-default login      ← authorizes Python/SDK libraries (ADC)
#   Missing either one leaves half the automation unauthorized.
# Org policy iam.disableServiceAccountKeyCreation is NOT enforced (lifted 2026-06-24, permanent)
GOOGLE_CLOUD_PROJECT=custom-frame-500419-s3
GOOGLE_CLOUD_ORG_ID=__set_me__             # gcloud organizations list --format="value(name)"

# --- Hetzner / host bootstrap (non-secret host metadata + optional automation tokens) ---
HETZNER_SERVER_IP=__set_me__
HETZNER_SERVER_NAME=PE-open-brain
HETZNER_SERVER_TYPE=CPX41
HETZNER_SSH_USER=deploy
HETZNER_SSH_PORT=22
HETZNER_API_TOKEN=__set_me__                  # optional; only if automating Hetzner Cloud changes
ORGO_API_KEY=__set_me__                       # Orgo desktops for named agent browser/portal work
ORGO_WORKSPACE_ID=__set_me__                  # existing Orgo workspace for Pro Exteriors agent desktops

# --- Embeddings / models ---
EMBEDDINGS_PROVIDER=managed                   # managed | ollama
EMBEDDINGS_API_KEY=__set_me__                 # if managed
OLLAMA_BASE_URL=http://localhost:11434        # if EMBEDDINGS_PROVIDER=ollama (local profile)

# --- MemSearch / semantic memory ---
# Default local mode uses ONNX + Milvus Lite and does not need an API key.
OPENAI_API_KEY=__set_me__                     # optional: OpenAI embeddings or MemSearch managed summarization
ZILLIZ_CLOUD_URI=__set_me__                   # optional: remote Milvus/Zilliz Cloud URI for shared agent memory
ZILLIZ_CLOUD_TOKEN=__set_me__                 # optional: remote Milvus/Zilliz Cloud token
ZILLIZ_URI=__set_me__                         # accepted local alias used by MemSearch/Zilliz tooling
ZILLIZ_TOKEN=__set_me__                       # accepted local alias used by MemSearch/Zilliz tooling
MILVUS_URI=__set_me__                         # optional self-hosted Milvus Server, e.g. http://milvus:19530
MILVUS_TOKEN=__set_me__                       # optional self-hosted Milvus auth token

# --- Slack (vertical agent bots) ---
SLACK_BOT_TOKEN=xoxb-__set_me__
SLACK_SIGNING_SECRET=__set_me__
SLACK_APP_TOKEN=xapp-__set_me__
SLACK_ACCOUNTING_CREDIT_MEMOS_CHANNEL_ID=__set_me__
SLACK_ACCOUNTING_VENDOR_INTAKE_CHANNEL_ID=__set_me__
SLACK_ACCOUNTING_PRODUCT_CATALOG_REVIEW_CHANNEL_ID=__set_me__
SLACK_OB_CONDUCTOR_DIGEST_CHANNEL_ID=__set_me__
SLACK_OB_AGENT_AUDIT_LOG_CHANNEL_ID=__set_me__
SLACK_OB_QC_REVIEW_CHANNEL_ID=__set_me__

# --- AgentMail (agent inboxes + signed inbound event webhooks) ---
AGENTMAIL_API_KEY=am_us___set_me__
AGENTMAIL_DOMAIN=agentmail.proexteriorsus.net
AGENTMAIL_WEBHOOK_URL=https://cc.proexteriorsus.net/api/agentmail/webhook
AGENTMAIL_WEBHOOK_SECRET=whsec___set_me__       # single endpoint; prefer AGENTMAIL_WEBHOOK_SECRETS when multiple endpoints post here
AGENTMAIL_WEBHOOK_SECRETS=__set_me__            # comma-separated whsec_ values; never public

# --- Bridges (only set the ones enabled in roofer.config.yaml) ---
GHL_API_KEY=__set_me__                        # Go High Level (primary CRM); or use OAuth
GHL_LOCATION_ID=__set_me__
GHL_WEBHOOK_SECRET=__set_me__
# GHL internal API — required for workflow creation (public API is read-only for workflows)
# Get via Chrome extension: GHL - Claude CLI/chrome-extension → Grab Refresh Token
GHL_FIREBASE_REFRESH_TOKEN=__set_me__         # Firebase session; renews ~monthly via extension
ACCULYNX_API_KEY=__set_me__
ACCULYNX_WEBHOOK_SECRET=__set_me__
COMPANYCAM_API_KEY=__set_me__
QUICKBOOKS_CLIENT_ID=__set_me__
QUICKBOOKS_CLIENT_SECRET=__set_me__
QUICKBOOKS_REFRESH_TOKEN=__set_me__
EAGLEVIEW_API_KEY=__set_me__
STARTINFINITY_API_KEY=__set_me__

# ABC Supply sandbox/prod bridge. If ABC's portal labels these as ClientID
# and Client_Secret, mirror those same values into the namespaced vars below.
ABC_SUPPLY_ENV=sandbox                       # sandbox | production
ABC_SUPPLY_CLIENT_ID=__set_me__
ABC_SUPPLY_CLIENT_SECRET=__set_me__
ABC_SUPPLY_WEBHOOK_SECRET=__set_me__
ABC_SUPPLY_REFRESH_TOKEN=__set_me__          # only for auth-code flows
ABC_SUPPLY_API_BASE_URL=https://partners-sb.abcsupply.com
ABC_SUPPLY_AUTH_BASE_URL=https://sandbox.auth.partners.abcsupply.com/oauth2/aus1vp07knpuqf6Xz0h8
ABC_SUPPLY_SCOPES=location.read product.read account.read pricing.read order.read allOrder.read notification.read invoice.read invoice.history.read

# --- WorkOS (Command Center human + named-agent auth) — see docs/34-workos-human-auth-spec.md ---
WORKOS_API_KEY=__set_me__
WORKOS_CLIENT_ID=__set_me__
WORKOS_REDIRECT_URI=https://cc.proexteriorsus.net/auth/callback
WORKOS_COOKIE_PASSWORD=__set_me__             # >=32 chars; seals the session cookie (openssl rand -base64 32)
COMMAND_CENTER_ROLE_PURCHASING_EMAILS=__set_me__   # comma-separated; approval.decide in accounting+operations
COMMAND_CENTER_ROLE_ACCOUNTING_EMAILS=__set_me__   # comma-separated; approval.decide in accounting
COMMAND_CENTER_VIEWER_DOMAINS=__set_me__           # comma-separated email domains allowed read-only viewer access

# --- Sentry (error monitoring + session replay; org=cleverwork project=cc-proexteriorsus) ---
# RUNTIME (set in Coolify on the runner): server SSR + Node background runtimes read these.
SENTRY_DSN=__set_me__                         # https://<publicKey>@oNNN.ingest.us.sentry.io/<projectId>
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=__set_me__                     # git commit SHA of the deploy (ties errors to a build)
# BUILD-TIME (Coolify build args; baked into the client bundle / used for source-map upload):
PUBLIC_SENTRY_DSN=__set_me__                  # same value as SENTRY_DSN — exposed to the browser SDK
SENTRY_AUTH_TOKEN=__set_me__                  # org token w/ project:releases + org:read — SECRET, build only
# Tooling / API automation (optional):
SENTRY_ORG=cleverwork
SENTRY_PROJECT=cc-proexteriorsus
SENTRY_MCP_URL=https://mcp.sentry.dev/mcp     # can constrain to /ORG or /ORG/PROJECT

# --- WorkOS/auth.md agent registration discovery ---
AGENT_AUTH_ISSUER=https://cc.proexteriorsus.net
AGENT_AUTH_SIGNING_KEY=__set_me__             # future service-signed identity_assertion key material; never public
AGENT_AUTH_TRUSTED_ISSUERS=__set_me__         # comma-separated agent-provider issuer URLs
COMMAND_CENTER_HUMAN_ADMIN_EMAILS=admin@cc.proexteriorsus.net
AGENT_SERVICE_TOKENS=__set_me__               # comma-separated agent-id:token pairs for phase-1 machine access

# --- Google Maps Platform (vendor territory map + drive-time isochrones) ---
# Two restricted keys recommended. Browser key is exposed in page source by design.
GOOGLE_MAPS_BROWSER_KEY=__set_me__            # Maps JavaScript API only; restrict by HTTP referrer
GOOGLE_MAPS_SERVER_KEY=__set_me__             # Geocoding API + Routes API only; restrict by IP

# --- Meeting capture (post-op debrief transcription) ---
GRANOLA_API_KEY=__set_me__
FIREFLIES_API_KEY=__set_me__

# --- Ops ---
BACKUP_ENCRYPTION_KEY=__set_me__              # for scripts/ brain-backup
BACKUP_STORAGE_BUCKET=__set_me__              # offsite encrypted backup destination
BACKUP_STORAGE_ENDPOINT=__set_me__            # S3-compatible endpoint when applicable
BACKUP_STORAGE_ACCESS_KEY_ID=__set_me__
BACKUP_STORAGE_SECRET_ACCESS_KEY=__set_me__

# --- Database labs (non-production only by default) ---
GHOST_API_KEY=__set_me__
GHOST_SPACE_ID=__set_me__
GHOST_DEFAULT_DATABASE=__set_me__
DOLT_REMOTE_URL=__set_me__
DOLT_USER=__set_me__
DOLT_EMAIL=__set_me__
DOLTHUB_TOKEN=__set_me__

# Unstructured.io OCR (price-list / vendor-doc ingest)
UNSTRUCTURED_API_KEY=your-unstructured-api-key
UNSTRUCTURED_API_URL=https://platform.unstructuredapp.io/api/v1
