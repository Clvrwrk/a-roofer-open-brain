---
import "../styles/global.css";
import { getCommandCenterUser, isWorkOsConfigured } from "@lib/auth";
import { type LiveDepartmentSurface } from "@lib/live-work";
import { navHome, navDepartments, activeDepartmentId, isLeafActive } from "@lib/nav";
import { APP_VERSION, APP_VERSION_DATE } from "@lib/version";

interface Props {
  title: string;
  eyebrow?: string;
  activePage?: "command" | "agents" | "pricing" | "territories" | "data-quality" | "snapshot" | "accounting" | "operations" | "sales" | "marketing" | "executive" | "system";
  layoutMode?: "default" | "map";
  surface?: Pick<LiveDepartmentSurface, "items" | "status">;
}

const { title, eyebrow = "Command Center", activePage = "command", layoutMode = "default" } = Astro.props;
const actor = Astro.locals.actor;
const user = getCommandCenterUser(actor);
const workOsReady = isWorkOsConfigured();
const workOsSession = user.authMode === "workos";

const pathname = Astro.url.pathname;
const homeActive = isLeafActive(navHome, pathname);
const openDepartment = activeDepartmentId(pathname);
const actorCacheId = actor?.id ?? user.email ?? user.name ?? "local-operator";

// Topical line icons (24x24, stroke = currentColor → inherits --accent).
const icons: Record<string, string> = {
  map: '<path d="M9 4 3 6.5v13L9 17l6 2.5 6-2.5v-13L15 6.5 9 4Z"/><path d="M9 4v13M15 6.5v13"/>',
  accounting:
    '<path d="M4 3h13l3 3v15H4Z"/><path d="M8 8h8M8 12h8M8 16h5"/>',
  operations:
    '<circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9 17 7M7 17l-2.1 2.1"/>',
  sales: '<path d="M4 19V5M4 19h16"/><path d="m7 14 3-4 3 3 5-7"/><path d="M18 6h2v2"/>',
  executive:
    '<path d="M4 21V10M10 21V4M16 21v-7M22 21H2"/>',
  "ai-agents":
    '<rect x="6" y="8" width="12" height="10" rx="2"/><path d="M12 8V4M9 4h6M9 13h.5M14.5 13h.5"/><path d="M4 12h2M18 12h2"/>',
};
const homeIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons.map}</svg>`;
const deptIcon = (id: string) =>
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${icons[id] ?? icons.map}</svg>`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Open Brain Command Center" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Open Brain</title>
  </head>
  <body>
    <div class="app-frame">
      <aside class="side-rail" aria-label="Department navigation">
        <a class="brand-lockup" href="/">
          <img src="/pro-exteriors-logo.svg" alt="Pro Exteriors" width="160" height="58" />
        </a>

        <nav class="primary-nav" aria-label="Primary">
          <a class:list={["nav-link", "nav-home", homeActive && "is-active"]} href={navHome.href} aria-current={homeActive ? "page" : undefined}>
            <span class="nav-icon" aria-hidden="true" set:html={homeIcon} />
            {navHome.label}
          </a>
        </nav>

        <div class="department-stack" aria-label="Departments">
          <p class="rail-label">Departments</p>
          {
            navDepartments.map((department) => (
              <details class="dept" open={openDepartment === department.id} data-department={department.id}>
                <summary class="dept-summary">
                  <span class="nav-icon" aria-hidden="true" set:html={deptIcon(department.icon)} />
                  <span class="dept-label">{department.label}</span>
                  <span class="dept-chevron" aria-hidden="true">›</span>
                </summary>
                <ul class="dept-items">
                  {department.items.map((item) =>
                    item.status === "built" && item.href ? (
                      <li>
                        <a
                          class:list={["dept-link", isLeafActive(item, pathname) && "is-active"]}
                          href={item.href}
                          aria-current={isLeafActive(item, pathname) ? "page" : undefined}
                          title={item.note}
                        >
                          {item.label}
                        </a>
                      </li>
                    ) : (
                      <li>
                        <span class="dept-link is-soon" title={item.note} aria-disabled="true">
                          {item.label}
                          <small class="soon-badge">soon</small>
                        </span>
                      </li>
                    ),
                  )}
                </ul>
              </details>
            ))
          }
        </div>
      </aside>

      <div class:list={["app-main", layoutMode === "map" && "app-main-map"]}>
        <header class="top-bar">
          <div>
            <p class="eyebrow">{eyebrow}</p>
            <h1>{title}</h1>
          </div>

          <div class="operator-cluster" aria-label="Runtime summary">
            <div class="runtime-pill-stack">
              <div class="runtime-pill" data-tone={workOsSession ? "ready" : "watch"}>
                <span class="signal-dot" aria-hidden="true"></span>
                {workOsSession ? "WorkOS session" : workOsReady ? "WorkOS ready" : "Local auth"}
              </div>
              <p class="app-version" title="App version · last updated">v{APP_VERSION} · {APP_VERSION_DATE}</p>
            </div>
            <div class="operator-card">
              <strong>{user.name}</strong>
              <span>{user.role}</span>
            </div>
            {
              workOsSession && (
                <form action="/auth/logout" method="POST" class="logout-form">
                  <button type="submit" class="logout-button">Sign out</button>
                </form>
              )
            }
          </div>
        </header>

        <main>
          <slot />
        </main>
      </div>
    </div>
    <script>
      // Accordion: open one department at a time. Native <details> allows
      // multiple open; close the others when a new summary is opened.
      const groups = Array.from(document.querySelectorAll<HTMLDetailsElement>(".dept"));
      for (const group of groups) {
        group.addEventListener("toggle", () => {
          if (!group.open) return;
          for (const other of groups) {
            if (other !== group) other.open = false;
          }
        });
      }
    </script>

    <script define:vars={{ actorCacheId }}>
      (() => {
        const pageRoutes = [
          "/",
          "/accounting/invoice-audit",
          "/accounting/price-list/review",
          "/operations/order-audit",
          "/operations/estimate-audit",
          "/weekly-snapshot",
          "/accounting/vendor-regions",
          "/accounting",
          "/operations",
          "/sales",
          "/marketing",
          "/executive",
          "/system",
        ];
        let cacheWorker = null;
        function postToWorker(message) {
          const worker = navigator.serviceWorker?.controller || cacheWorker;
          if (worker) worker.postMessage(message);
        }

        function pageLooksComplete() {
          const bodyText = document.body?.textContent?.toLowerCase() || "";
          if (bodyText.includes("supabase pending")) return false;
          if (bodyText.includes("no invoices found in the live pipeline")) return false;
          if (bodyText.includes("loading invoice detail")) return false;
          if (bodyText.includes("territory data failed to load")) return false;
          if (bodyText.includes("map unavailable")) return false;
          if (document.querySelector(".iv-inv-body[data-rendered='1']") && !document.querySelector(".iv-ln")) return false;
          return document.documentElement.outerHTML.length > 2000;
        }

        function renderedHtmlSnapshot() {
          const clone = document.documentElement.cloneNode(true);
          clone.dataset.commandCenterSnapshot = "last-complete-render";
          return "<!doctype html>\\n" + clone.outerHTML;
        }

        function cacheCurrentRendering() {
          if (!pageLooksComplete()) return;
          postToWorker({ type: "CACHE_RENDERED_PAGE", path: location.pathname, html: renderedHtmlSnapshot() });
        }

        async function browserPrecache() {
          if (!("caches" in window)) return;
          for (const route of pageRoutes) {
            try {
              await fetch(route, { credentials: "include", headers: { accept: "text/html" } });
            } catch {
              // Browser-side cache warming is opportunistic; navigation still works without it.
            }
          }
        }

        function debounce(fn, wait) {
          let timer;
          return () => {
            clearTimeout(timer);
            timer = setTimeout(fn, wait);
          };
        }

        const scheduleRenderCache = debounce(cacheCurrentRendering, 900);

        async function registerCacheWorker() {
          if (!("serviceWorker" in navigator)) return;
          try {
            const registration = await navigator.serviceWorker.register("/sw.js", { scope: "/" });
            const ready = await navigator.serviceWorker.ready;
            const worker = ready.active || registration.active || registration.waiting || registration.installing;
            cacheWorker = worker || null;
            worker?.postMessage({ type: "SET_ACTOR", actorId: actorCacheId });
            cacheCurrentRendering();
            worker?.postMessage({ type: "PRECACHE", urls: pageRoutes });
            navigator.serviceWorker.addEventListener("controllerchange", () => {
              cacheWorker = navigator.serviceWorker.controller;
              postToWorker({ type: "SET_ACTOR", actorId: actorCacheId });
              cacheCurrentRendering();
              postToWorker({ type: "PRECACHE", urls: pageRoutes });
            });
          } catch {
            // Cache worker is an accelerator only; never block the app shell on it.
          }
        }

        window.addEventListener("load", () => {
          void registerCacheWorker();
          setTimeout(cacheCurrentRendering, 1200);
          setTimeout(() => void browserPrecache(), 1500);
        });

        document.addEventListener("click", scheduleRenderCache, true);
        document.addEventListener("input", scheduleRenderCache, true);
        document.addEventListener("change", scheduleRenderCache, true);
        document.addEventListener("toggle", scheduleRenderCache, true);
        document.addEventListener("command-center:render-ready", scheduleRenderCache);
        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") cacheCurrentRendering();
        });
        window.addEventListener("pagehide", cacheCurrentRendering);

        document.querySelector(".logout-form")?.addEventListener("submit", () => {
          postToWorker({ type: "CLEAR" });
        });
      })();
    </script>
  </body>
</html>
