---
import AppShell from "../../layouts/AppShell.astro";
import { loadWeeklySnapshot } from "@lib/weekly-snapshot";
import { getWeeklySnapshotSlice } from "@lib/weekly-snapshot-routes";

const slice = Astro.params.slice;
const snapshot = await loadWeeklySnapshot();
const view = getWeeklySnapshotSlice(snapshot, slice);

if (!view) {
  Astro.response.status = 404;
}
---

<AppShell title={view?.title ?? "Snapshot Slice Not Found"} eyebrow="Weekly Snapshot Drilldown" activePage="snapshot">
  {
    view ? (
      <section class="snapshot-detail-page" aria-label={`${view.title} detail`}>
        <div class="surface-heading">
          <div>
            <p class="eyebrow">{snapshot.window.label}</p>
            <h2>{view.description}</h2>
          </div>
          <div class="surface-meta">
            <span class="runtime-pill" data-tone={snapshot.status === "live" ? "ready" : "watch"}>
              <span class="signal-dot" aria-hidden="true"></span>
              {snapshot.status}
            </span>
            <a class="row-action" href="/weekly-snapshot">Snapshot</a>
          </div>
        </div>

        {view.rows.length > 0 && (
          <div class="gap-summary-grid">
            {view.rows.slice(0, 8).map((row) => (
              <a class="gap-metric-card" href={row.href}>
                <span>{row.value}</span>
                <strong>{row.label}</strong>
                <small>{row.secondary}</small>
              </a>
            ))}
          </div>
        )}

        <div class="snapshot-detail-table-panel">
          <div class="panel-heading">
            <div>
              <p class="eyebrow">Information Page</p>
              <h2>{view.records.length} records</h2>
            </div>
          </div>

          <div class="queue-table-wrap">
            <table class="queue-table snapshot-detail-table">
              <thead>
                <tr>
                  <th scope="col">Type</th>
                  <th scope="col">Record</th>
                  <th scope="col">Value</th>
                  <th scope="col">Status</th>
                  <th scope="col">Open</th>
                </tr>
              </thead>
              <tbody>
                {view.records.length > 0 ? (
                  view.records.map((record) => (
                    <tr>
                      <td>{record.type}</td>
                      <td><strong>{record.label}</strong><span>{record.sublabel}</span></td>
                      <td>{record.value}</td>
                      <td>{record.status}</td>
                      <td><a class="row-action" href={record.href}>Open</a></td>
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colspan="5">No records are available for this slice yet.</td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    ) : (
      <section class="snapshot-detail-page">
        <div class="snapshot-alert">No weekly snapshot detail route exists for "{slice}".</div>
      </section>
    )
  }
</AppShell>
