---
import AppShell from "../layouts/AppShell.astro";
import LiveMetricGrid from "../components/live/LiveMetricGrid.astro";
import LiveWorkQueue from "../components/live/LiveWorkQueue.astro";
import { departments, loadCommandCenterSurface } from "@lib/live-work";

const surface = await loadCommandCenterSurface();
const generatedAt = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
  month: "short",
}).format(new Date(surface.generatedAt));
const tone = surface.status === "live" ? "ready" : surface.status === "degraded" ? "watch" : "blocked";
---

<AppShell title="Human Approval Queue" eyebrow="Live Command Center" activePage="command" surface={surface}>
  <section class="live-department-hero" aria-label="Live command center summary">
    <div class="surface-heading">
      <div>
        <p class="eyebrow">Dashboard Source Of Truth</p>
        <h2>All human decisions routed from live operational source rows.</h2>
      </div>
      <div class="surface-meta">
        <span class="runtime-pill" data-tone={tone}>
          <span class="signal-dot" aria-hidden="true"></span>
          {surface.status}
        </span>
        <span>{generatedAt}</span>
      </div>
    </div>

    {
      surface.errors.length > 0 && (
        <div class="accounting-boundary-notice">
          <strong>Live data issue</strong>
          <span>{surface.errors.join(" ")}</span>
        </div>
      )
    }

    <LiveMetricGrid metrics={surface.metrics} />
  </section>

  <section class="department-route-grid" aria-label="Department dashboards">
    {
      departments.map((department) => {
        const count = surface.items.filter((item) => item.department === department.id).length;
        const blocked = surface.items.filter((item) => item.department === department.id && item.status === "blocked").length;
        return (
          <a class="department-route-card" href={`/${department.id}`}>
            <span>{department.agent}</span>
            <strong>{department.label}</strong>
            <small>{count} live items · {blocked} blocked</small>
          </a>
        );
      })
    }
  </section>

  <LiveWorkQueue items={surface.items} emptyLabel="No live source-backed work items are open across departments." />

  <script src="/src/scripts/command-center.ts"></script>
</AppShell>
