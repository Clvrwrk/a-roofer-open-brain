---
import AppShell from "../../layouts/AppShell.astro";
import { loadOrderAudit } from "@lib/order-audit";

const data = await loadOrderAudit();
const generatedAt = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" }).format(new Date(data.generatedAt));
const runtimeTone = data.status === "live" ? "ready" : "watch";
const runtimeLabel = data.status === "live" ? "Supabase live" : "Supabase pending";
const offices = data.offices.map((o) => o.office);
const money = (n: number) => "$" + Math.round(n).toLocaleString("en-US");
const matchPct = data.totals.active ? Math.round((data.totals.matched / data.totals.active) * 100) : 0;

const payload = JSON.stringify({ offices: data.offices, categories: data.categories }).replace(/</g, "\\u003c");
const cutoff = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric" }).format(new Date(Date.now() - 60 * 864e5));
---

<AppShell title="Order Audit" eyebrow="Operations" activePage="operations">
  <section class="iv" data-theme="light" data-pref="system">
    <div class="iv-toolbar">
      <input class="iv-input" id="iv-search" type="search" placeholder="Search order, PO, job, item, branch…" autocomplete="off" />
      <select class="iv-select" id="iv-office">
        <option value="">All PE offices</option>
        {offices.map((o) => <option value={o}>{o}</option>)}
      </select>
      <select class="iv-select" id="iv-status">
        <option value="active">Active (last 60 days)</option>
        <option value="archived">Archived (invoiced / aged)</option>
        <option value="">All orders</option>
      </select>
      <select class="iv-select" id="iv-tol">
        <option value="">All tolerance</option>
        <option value="0.01">Flagged ≥ Minor</option>
        <option value="3">Moderate +</option>
        <option value="6">Major only</option>
        <option value="noprice">No-agreement lines</option>
      </select>
      <select class="iv-select" id="iv-match">
        <option value="">All matches</option>
        <option value="matched">Matched to job</option>
        <option value="unmatched">Unmatched (no PE job)</option>
      </select>
      <span class="iv-spacer"></span>
      <span class="runtime-pill" data-tone={runtimeTone}><span class="signal-dot" aria-hidden="true"></span>{runtimeLabel}</span>
      <span class="iv-count">{generatedAt}</span>
      <div class="iv-theme" role="group" aria-label="Theme">
        <button type="button" data-set-theme="system" class="is-active">System</button>
        <button type="button" data-set-theme="light">Light</button>
        <button type="button" data-set-theme="dark">Dark</button>
      </div>
    </div>

    <div class="iv-kpis">
      <div class="iv-kpi"><span class="iv-kpi-lab">Active Orders</span><span class="iv-kpi-val">{data.totals.active.toLocaleString()}</span><span class="iv-kpi-sub">last 60 days · {data.totals.archived.toLocaleString()} archived</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">$ At Risk</span><span class="iv-kpi-val">{money(data.totals.atRisk)}</span><span class="iv-kpi-sub">overcharge vs negotiated</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">Flagged Lines</span><span class="iv-kpi-val">{data.totals.flaggedLines.toLocaleString()}</span><span class="iv-kpi-sub">priced above agreement</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">Matched to Job</span><span class="iv-kpi-val">{data.totals.matched.toLocaleString()}</span><span class="iv-kpi-sub">{matchPct}% verified to AcuLynx</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">No-Agreement Lines</span><span class="iv-kpi-val">{data.totals.uncoveredLines.toLocaleString()}</span><span class="iv-kpi-sub">no negotiated price</span></div>
    </div>

    <p class="iv-note">Catches vendor pricing issues at the <b>order</b> stage — before they reach <a href="/accounting/invoice-audit">Invoice Audit</a>. Order unit price (ABC API) is compared to the negotiated agreement price; overcharges surface as <b>$ at risk</b>. Orders auto-archive (by <code>system</code>) once invoiced or older than 60 days (before {cutoff}); the view defaults to the active window.</p>

    {data.totals.orders === 0 && <p class="iv-empty">No orders found in the live pipeline.</p>}
    <div id="iv-tree"></div>
  </section>

  <script type="application/json" id="iv-data" set:html={payload}></script>
</AppShell>

<style is:global>
  .iv{
    --bg:#f4f6f9; --panel:#ffffff; --panel2:#f7f8fb; --ink:#1c2733; --muted:#6b7886; --line:#e3e8ef;
    --brand:#5b46d8; --brand-bg:#efecfd; --green:#137a4d; --green-bg:#e3f5ec; --yellow:#946400; --yellow-bg:#fbf0d4;
    --orange:#a4480d; --orange-bg:#fbe7d6; --red:#a51f1f; --red-bg:#fbe2e2; --grey:#5a6573; --grey-bg:#eceff4; --shadow:0 6px 18px rgba(20,28,40,.08);
    background:var(--bg); color:var(--ink);
    margin:calc(-1 * var(--space-4, 16px)) calc(-1 * var(--gutter, 24px)) calc(-1 * var(--space-6, 24px));
    padding:18px var(--gutter, 24px) 30px; min-height:70vh; font-family:var(--font-sans, Inter, system-ui, sans-serif);
  }
  .iv[data-theme="dark"]{
    --bg:#0f141b; --panel:#161d27; --panel2:#1c2530; --ink:#e6edf5; --muted:#8b98a8; --line:#27313e;
    --brand:#8a7bff; --brand-bg:#21243f; --green:#7ee2ad; --green-bg:#123626; --yellow:#f2cf6b; --yellow-bg:#3a3115;
    --orange:#f3a766; --orange-bg:#3d2913; --red:#ff8585; --red-bg:#3d1a1a; --grey:#9aa6b4; --grey-bg:#222c38; --shadow:0 6px 18px rgba(0,0,0,.4);
  }
  .iv .pill{display:inline-block;padding:2px 9px;border-radius:999px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.5}
  .iv .pill-green{background:var(--green-bg);color:var(--green)}
  .iv .pill-yellow{background:var(--yellow-bg);color:var(--yellow)}
  .iv .pill-orange{background:var(--orange-bg);color:var(--orange)}
  .iv .pill-red{background:var(--red-bg);color:var(--red)}
  .iv .pill-grey{background:var(--grey-bg);color:var(--grey)}
  .iv .pill-brand{background:var(--brand-bg);color:var(--brand)}

  .iv-toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px}
  .iv-input,.iv-select{background:var(--panel);border:1px solid var(--line);color:var(--ink);border-radius:8px;padding:8px 11px;font-size:13px;font-family:inherit}
  .iv-input{min-width:240px}
  .iv-spacer{flex:1}
  .iv-count{font-size:12px;color:var(--muted)}
  .iv-empty{color:var(--muted);font-size:13px;padding:14px 4px}
  .iv-note{color:var(--muted);font-size:12px;line-height:1.5;margin:0 0 16px;max-width:980px}
  .iv-note a{color:var(--brand);text-decoration:none}.iv-note a:hover{text-decoration:underline}
  .iv-theme{display:inline-flex;border:1px solid var(--line);border-radius:9px;overflow:hidden;background:var(--panel)}
  .iv-theme button{appearance:none;border:none;background:transparent;color:var(--muted);font-size:12px;font-weight:600;padding:7px 12px;cursor:pointer;font-family:inherit}
  .iv-theme button.is-active{background:var(--brand);color:#fff}

  .iv-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:18px}
  .iv-kpi{display:flex;flex-direction:column;gap:3px;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:13px 15px}
  .iv-kpi-lab{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);font-weight:600}
  .iv-kpi-val{font-size:22px;font-weight:750;font-variant-numeric:tabular-nums}
  .iv-kpi-sub{font-size:11px;color:var(--muted)}

  .iv-office{background:var(--panel);border:1px solid var(--line);border-radius:14px;margin-bottom:12px;overflow:hidden}
  .iv-office>summary{display:flex;align-items:center;gap:14px;padding:14px 16px;cursor:pointer;list-style:none}
  .iv-office>summary::-webkit-details-marker{display:none}
  .iv-chev{color:var(--muted);transition:transform .15s;font-size:15px}
  details[open]>summary .iv-chev{transform:rotate(90deg)}
  .iv-office-name{font-weight:750;font-size:15px;flex:1}
  .iv-mini{display:flex;gap:16px}
  .iv-mini div{text-align:center}
  .iv-mini strong{display:block;font-size:15px;font-weight:750;font-variant-numeric:tabular-nums}
  .iv-mini span{font-size:10px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted)}
  .iv-office-body{padding:4px 12px 12px;border-top:1px solid var(--line)}

  .iv-branch{border:1px solid var(--line);border-radius:11px;margin:10px 0;background:var(--panel2)}
  .iv-branch>summary{display:flex;align-items:center;gap:12px;padding:11px 13px;cursor:pointer;list-style:none;flex-wrap:wrap}
  .iv-branch>summary::-webkit-details-marker{display:none}
  .iv-branch-name{font-weight:700;font-size:13.5px}
  .iv-branch-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap}
  .iv-branch-body{padding:4px 12px 12px}

  .iv-inv{border:1px solid var(--line);border-radius:10px;margin:8px 0;background:var(--panel)}
  .iv-inv>summary{display:flex;align-items:center;gap:12px;padding:10px 12px;cursor:pointer;list-style:none;flex-wrap:wrap}
  .iv-inv>summary::-webkit-details-marker{display:none}
  .iv-inv-no{font-weight:700;font-size:13px}
  .iv-inv-sub{color:var(--muted);font-size:11.5px}
  .iv-pricelist{margin:0 auto;border:1px solid var(--line);border-radius:999px;padding:3px 12px;font-size:12px;font-weight:650;color:var(--brand);text-decoration:none;background:var(--panel);white-space:nowrap}
  .iv-pricelist:hover{border-color:var(--brand);background:var(--brand-bg)}
  .iv-inv-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .iv-inv-body{padding:4px 12px 12px;border-top:1px solid var(--line)}

  /* roof-system category sections (collapsible, default-collapsed) — mirrors Invoice Audit */
  .iv-cats{margin-top:6px}
  .iv-cat{border:1px solid var(--line);border-radius:8px;margin:6px 0;background:var(--panel2)}
  .iv-cat>summary{display:flex;align-items:center;gap:10px;padding:8px 11px;cursor:pointer;list-style:none}
  .iv-cat>summary::-webkit-details-marker{display:none}
  .iv-cat>summary b{font-size:12.5px}
  .iv-cat-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .iv-cat-sub{font-variant-numeric:tabular-nums;font-weight:650;font-size:12px;color:var(--muted)}
  .iv-cat .iv-table{margin:0 8px 8px}

  .iv-disp-lead{font-size:12.5px;color:var(--muted);margin-bottom:10px}
  .iv-table{width:100%;border-collapse:collapse;margin-top:6px}
  .iv-table thead th{font-size:10px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted);text-align:left;padding:8px 9px;border-bottom:1px solid var(--line);background:var(--panel2);white-space:nowrap}
  .iv-table td{padding:7px 9px;border-bottom:1px solid var(--line);font-size:12.5px}
  .iv-table td.num{text-align:right;font-variant-numeric:tabular-nums}
  .iv-sku{font-family:ui-monospace,Menlo,monospace;font-size:11.5px}
  .iv-note code{font-family:ui-monospace,Menlo,monospace;font-size:11px;background:var(--grey-bg);color:var(--grey);padding:1px 5px;border-radius:5px}

  .iv-job{color:var(--brand);font-weight:600}
  @media (max-width:1100px){ .iv-kpis{grid-template-columns:repeat(2,1fr)} }
</style>

<script src="/src/scripts/order-audit-tree.ts"></script>
