---
import AppShell from "../../layouts/AppShell.astro";
import {
  KNOWN_ACCOUNT_KEYS,
  formatCompactCurrency,
  loadExecutivePipelineDashboard,
  type DashboardFilters,
  type QueueName,
  type WindowToken,
} from "@lib/executive-pipeline";

const params = Astro.url.searchParams;

const WINDOW_TOKENS: WindowToken[] = ["this_week", "last_7_days", "mtd", "qtd"];
const WINDOW_LABELS: Record<WindowToken, string> = {
  this_week: "This Week",
  last_7_days: "Last 7 Days",
  mtd: "Month-to-Date",
  qtd: "Quarter-to-Date",
};

const COMMERCIAL_RESIDENTIAL_OPTIONS = ["Residential", "Commercial", "Property Management", "uncategorized"];

const MAX_REP_LENGTH = 120;
const SAFE_REP_PATTERN = /^[\w .,'’&()/-]+$/u;

function pickAllowlisted<T extends string>(value: string | null, allowed: readonly T[]): T | undefined {
  if (!value) return undefined;
  return (allowed as readonly string[]).includes(value) ? (value as T) : undefined;
}

// Checkpoint round 3, item 1: the Rep filter is data-driven, so it is sanitized (not
// allowlisted against a fixed compile-time set) — same discipline as the JSON API
// route (see pipeline.json.ts's sanitizeRep). Never built into a Supabase .eq()/.in()
// call; only ever used for in-memory JS string-equality filtering downstream.
function sanitizeRep(value: string | null): string | "all" | undefined {
  if (!value) return undefined;
  if (value === "all") return "all";
  if (value.length > MAX_REP_LENGTH) return undefined;
  if (!SAFE_REP_PATTERN.test(value)) return undefined;
  return value;
}

// Seed initial filters from the query string (SSR-friendly first paint) — same
// allowlist discipline the JSON API route enforces (Security V5 / T-07-04).
const seededWindow = pickAllowlisted(params.get("window"), WINDOW_TOKENS);
const seededAccountKey =
  params.get("location") === "all" ? "all" : pickAllowlisted(params.get("location"), KNOWN_ACCOUNT_KEYS);
const seededCommercialResidential =
  params.get("type") === "all"
    ? "all"
    : pickAllowlisted(params.get("type"), COMMERCIAL_RESIDENTIAL_OPTIONS as readonly string[]);
const seededRep = sanitizeRep(params.get("rep"));

const initialFilters: DashboardFilters = {
  ...(seededWindow ? { window: seededWindow } : {}),
  ...(seededAccountKey ? { accountKey: seededAccountKey } : {}),
  ...(seededCommercialResidential ? { commercialResidential: seededCommercialResidential } : {}),
  ...(seededRep ? { rep: seededRep } : {}),
};

const dashboard = await loadExecutivePipelineDashboard(initialFilters);

const ACCULYNX_JOB_BASE_URL = "https://proexteriors.acculynx.com/jobs";

function formatCurrency(value: number) {
  return new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }).format(value);
}

// One-line status strip (checkpoint rework directive 3) replaces the 9-pill wall.
// Oldest sync among the known production locations; stale-count for the summary line.
const oldestFreshness = dashboard.freshness.reduce<(typeof dashboard.freshness)[number] | null>((oldest, badge) => {
  if (!badge.lastSyncAt) return oldest;
  if (!oldest || !oldest.lastSyncAt) return badge;
  return new Date(badge.lastSyncAt) < new Date(oldest.lastSyncAt) ? badge : oldest;
}, null);

function relativeHours(value: string | null) {
  if (!value) return null;
  const ms = Date.now() - new Date(value).getTime();
  return Math.max(0, Math.floor(ms / 3_600_000));
}

const staleCount = dashboard.freshness.filter((badge) => badge.tone !== "ready").length;
const oldestHours = oldestFreshness ? relativeHours(oldestFreshness.lastSyncAt) : null;
const overallTone = staleCount === 0 ? "ready" : dashboard.freshness.some((b) => b.tone === "critical") ? "critical" : "review";
const statusStripText =
  dashboard.status === "live"
    ? `Data live${oldestHours !== null ? ` · oldest sync ${oldestHours}h ago` : ""}${
        staleCount > 0 ? ` · ${staleCount} location${staleCount === 1 ? "" : "s"} stale` : ""
      }`
    : "Data unavailable — showing the last successful load.";

const freshnessByAccount = new Map(dashboard.freshness.map((badge) => [badge.accountKey, badge]));

// Item 7: overall close rate KPI uses the count-based snapshot formula (window-
// independent) — same numbers the location rows and rep leaderboard now show,
// derived here from the residential/commercial split so the headline stays
// consistent with item 4's Res/Com pills without a second loader round-trip.
const overallCloseRatePct = (
  ((dashboard.closeRateSplit.residential + dashboard.closeRateSplit.commercial) / 2) * 100
).toFixed(0);

const overallMargin = dashboard.marginByRegion.reduce(
  (acc, row) => {
    acc.covered += row.coverage.jobsWithCostData;
    acc.total += row.coverage.totalJobsInSlice;
    return acc;
  },
  { covered: 0, total: 0 },
);
const marginCaption =
  overallMargin.covered === 0
    ? "No cost data available yet"
    : `${overallMargin.covered} of ${overallMargin.total} jobs have cost data`;
const avgMarginPct =
  overallMargin.covered > 0
    ? dashboard.marginByRegion.reduce((sum, row) => sum + row.marginPct * row.coverage.jobsWithCostData, 0) / overallMargin.covered
    : 0;

function asData(value: unknown) {
  return JSON.stringify(value);
}

const QUEUE_LABELS: Record<QueueName, string> = {
  leads: "Leads",
  prospects: "Prospects",
  approved: "Approved",
  invoiced: "Invoiced",
  closed: "Closed",
};
const QUEUE_ORDER: QueueName[] = ["leads", "prospects", "approved", "invoiced", "closed"];

// Per-location rows drive the primary breakdown + D-09 drill-down (checkpoint rework
// directive 6) — one row per production location (KNOWN_ACCOUNT_KEYS), showing the
// five-queue value/count breakdown + snapshot close rate (checkpoint round 3, item 3/7)
// instead of the old flat pipeline/sold/leads metrics.
interface LocationRow {
  accountKey: string;
  marginPct: number;
  coverageLabel: string;
  arValue: number;
  queues: { queue: QueueName; label: string; count: number; value: number | null }[];
  closeRateSnapshotPct: string;
  stale: boolean;
}

const marginByAccount = new Map(dashboard.marginByRegion.map((row) => [row.dimension, row]));
const rollupByAccount = new Map(dashboard.locationRollup.map((row) => [row.accountKey, row]));

const locationRows: LocationRow[] = KNOWN_ACCOUNT_KEYS.filter(
  (key) => dashboard.filters.accountKey === "all" || dashboard.filters.accountKey === key,
).map((accountKey) => {
  const margin = marginByAccount.get(accountKey);
  const freshness = freshnessByAccount.get(accountKey);
  const rollup = rollupByAccount.get(accountKey);
  const queuesByName = new Map((rollup?.queues ?? []).map((q) => [q.queue, q]));
  return {
    accountKey,
    marginPct: margin?.marginPct ?? 0,
    coverageLabel: margin
      ? margin.coverage.jobsWithCostData > 0
        ? `${margin.coverage.jobsWithCostData}/${margin.coverage.totalJobsInSlice}`
        : "no cost data"
      : "no data",
    arValue: rollup?.arValue ?? 0,
    queues: QUEUE_ORDER.map((queue) => {
      const q = queuesByName.get(queue);
      return { queue, label: QUEUE_LABELS[queue], count: q?.count ?? 0, value: q?.value ?? (queue === "leads" ? null : 0) };
    }),
    closeRateSnapshotPct: (((rollup?.closeRateSnapshot ?? 0) * 100).toFixed(0)),
    stale: freshness ? freshness.tone !== "ready" : false,
  };
});
---

<AppShell title="Sales Pipeline" eyebrow="AccuLynx + Open Brain" activePage="executive">
  <section class="epl" data-executive-pipeline>
    {
      dashboard.errors.length > 0 && (
        <div class="snapshot-alert" role="status" data-dashboard-errors>
          {dashboard.errors.map((error) => `${error} is unavailable right now — showing the last successful load.`).join(" ")}
        </div>
      )
    }

    <form class="epl-toolbar" aria-label="Global pipeline filters" data-filter-bar>
      <label class="select-label">
        <span>Location</span>
        <select name="location" data-filter="location">
          <option value="all" selected={dashboard.filters.accountKey === "all"}>All locations</option>
          {
            KNOWN_ACCOUNT_KEYS.map((key) => (
              <option value={key} selected={dashboard.filters.accountKey === key}>
                {key}
              </option>
            ))
          }
        </select>
      </label>
      <label class="select-label">
        <span>Type</span>
        <select name="type" data-filter="type">
          <option value="all" selected={dashboard.filters.commercialResidential === "all"}>All types</option>
          {
            COMMERCIAL_RESIDENTIAL_OPTIONS.map((option) => (
              <option value={option} selected={dashboard.filters.commercialResidential === option}>
                {option}
              </option>
            ))
          }
        </select>
      </label>
      <label class="select-label">
        <span>Rep</span>
        <select name="rep" data-filter="rep">
          <option value="all" selected={dashboard.filters.rep === "all"}>All reps</option>
          {
            dashboard.knownReps.map((repName) => (
              <option value={repName} selected={dashboard.filters.rep === repName}>
                {repName}
              </option>
            ))
          }
        </select>
      </label>
      <label class="select-label">
        <span>Window</span>
        <select name="window" data-filter="window">
          {
            WINDOW_TOKENS.map((token) => (
              <option value={token} selected={dashboard.filters.window === token}>
                {WINDOW_LABELS[token]}
              </option>
            ))
          }
        </select>
      </label>
      <span class="epl-spacer" />
      <button type="button" class="segment" data-reset-filters>
        Reset filters
      </button>
    </form>

    <div class="epl-status" data-tone={overallTone} data-status-strip>
      <span class="epl-status-dot" aria-hidden="true" />
      <span data-status-text>{statusStripText}</span>
    </div>

    <section class="epl-kpis" aria-label="Topline KPIs" data-kpi-grid>
      <div class="epl-kpi epl-kpi--split" data-kpi="pipeline-value">
        <span class="epl-kpi-lab">Pipeline Value</span>
        <strong class="epl-kpi-val" data-kpi-val="pipeline-value">{formatCurrency(dashboard.pipelineValueTotal)}</strong>
        <small class="epl-kpi-sub">Pre-close (prospects w/ estimate)</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="pipeline-value-residential">
              {formatCompactCurrency(dashboard.pipelineValueSplit.residential)}
            </span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="pipeline-value-commercial">
              {formatCompactCurrency(dashboard.pipelineValueSplit.commercial)}
            </span>
          </span>
        </span>
      </div>

      <div class="epl-kpi epl-kpi--split" data-kpi="sold-value">
        <span class="epl-kpi-lab">Sold Value</span>
        <strong class="epl-kpi-val" data-kpi-val="sold-value">{formatCurrency(dashboard.closeRate.soldValue)}</strong>
        <small class="epl-kpi-sub">{dashboard.window.label}</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="sold-value-residential">
              {formatCompactCurrency(dashboard.soldValueSplit.residential)}
            </span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="sold-value-commercial">
              {formatCompactCurrency(dashboard.soldValueSplit.commercial)}
            </span>
          </span>
        </span>
      </div>

      <div class="epl-kpi epl-kpi--split" data-kpi="jobs-sold">
        <span class="epl-kpi-lab">Jobs Sold</span>
        <strong class="epl-kpi-val" data-kpi-val="jobs-sold">{dashboard.closeRate.soldCount}</strong>
        <small class="epl-kpi-sub" data-kpi-sub="jobs-sold">{dashboard.window.label} (period snapshot)</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="jobs-sold-residential">{dashboard.jobsSoldSplit.residential}</span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="jobs-sold-commercial">{dashboard.jobsSoldSplit.commercial}</span>
          </span>
        </span>
      </div>

      <div class="epl-kpi epl-kpi--split" data-kpi="close-rate">
        <span class="epl-kpi-lab">Close Rate</span>
        <strong class="epl-kpi-val" data-kpi-val="close-rate">{overallCloseRatePct}%</strong>
        <small class="epl-kpi-sub">Snapshot: Approved+Invoiced+Closed / all</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="close-rate-residential">
              {(dashboard.closeRateSplit.residential * 100).toFixed(0)}%
            </span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="close-rate-commercial">
              {(dashboard.closeRateSplit.commercial * 100).toFixed(0)}%
            </span>
          </span>
        </span>
      </div>

      <div class="epl-kpi epl-kpi--split" data-kpi="new-leads">
        <span class="epl-kpi-lab">New Leads</span>
        <strong class="epl-kpi-val" data-kpi-val="new-leads">{dashboard.newLeadsCount}</strong>
        <small class="epl-kpi-sub">{dashboard.window.label}</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="new-leads-residential">{dashboard.newLeadsSplit.residential}</span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="new-leads-commercial">{dashboard.newLeadsSplit.commercial}</span>
          </span>
        </span>
      </div>

      <div class="epl-kpi epl-kpi--split" data-kpi="margin">
        <span class="epl-kpi-lab">Margin %</span>
        <strong class="epl-kpi-val" data-kpi-val="margin">{overallMargin.covered > 0 ? `${avgMarginPct.toFixed(0)}%` : "—"}</strong>
        <small class="epl-kpi-sub" data-kpi-sub="margin">{marginCaption}</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="margin-residential">{dashboard.marginPctSplit.residential.toFixed(0)}%</span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="margin-commercial">{dashboard.marginPctSplit.commercial.toFixed(0)}%</span>
          </span>
        </span>
      </div>

      <div class="epl-kpi epl-kpi--split" data-kpi="average-ticket">
        <span class="epl-kpi-lab">Average Ticket</span>
        <strong class="epl-kpi-val" data-kpi-val="average-ticket">
          {formatCurrency(dashboard.averageTicket.residential.avgTicket || dashboard.averageTicket.commercial.avgTicket)}
        </strong>
        <small class="epl-kpi-sub">Approved in {dashboard.window.label}</small>
        <span class="epl-kpi-split">
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Res</span>
            <span class="epl-kpi-split-val" data-kpi-split="average-ticket-residential">
              {formatCompactCurrency(dashboard.averageTicket.residential.avgTicket)}
            </span>
          </span>
          <span class="epl-kpi-split-item">
            <span class="epl-kpi-split-lab">Com</span>
            <span class="epl-kpi-split-val" data-kpi-split="average-ticket-commercial">
              {formatCompactCurrency(dashboard.averageTicket.commercial.avgTicket)}
            </span>
          </span>
        </span>
      </div>

      <div class="epl-kpi" data-kpi="ar-outstanding">
        <span class="epl-kpi-lab">AR Outstanding</span>
        <strong class="epl-kpi-val" data-kpi-val="ar-outstanding">{formatCurrency(dashboard.arTotal)}</strong>
        <small class="epl-kpi-sub">Across all reps</small>
      </div>
    </section>

    <section class="live-metric-grid" aria-label="Pipeline charts" data-chart-grid style="grid-template-columns: repeat(2, minmax(0, 1fr));">
      <div class="live-metric-card epl-chart-card">
        <span>Pipeline value by stage</span>
        <div class="epl-chart-wrap">
          <canvas id="pipeline-funnel-chart" data-chart="funnel" data-chart-data={asData(dashboard.funnel)} />
        </div>
      </div>

      <div class="live-metric-card epl-chart-card">
        <span>Rep leaderboard (sold value)</span>
        <div class="epl-chart-wrap">
          <canvas id="pipeline-leaderboard-chart" data-chart="leaderboard" data-chart-data={asData(dashboard.leaderboard)} />
        </div>
      </div>
    </section>

    <section aria-label="Locations" data-locations-section>
      <div class="epl-locations" data-locations-list>
        {
          locationRows.map((row) => (
            <details class="epl-location" data-location-row data-account-key={row.accountKey}>
              <summary>
                <span class="epl-chev" aria-hidden="true">
                  {"›"}
                </span>
                <span class="epl-location-name">{row.accountKey}</span>
                {row.stale && <span class="epl-stale-marker">stale</span>}
                <span class="epl-queues">
                  {row.queues.map((q) => (
                    <span class="epl-queue" data-queue={q.queue}>
                      <strong>{q.value === null ? q.count : formatCompactCurrency(q.value)}</strong>
                      <span>{q.label}{q.value !== null ? ` (${q.count})` : ""}</span>
                    </span>
                  ))}
                </span>
                <span class="epl-mini">
                  <div>
                    <strong>{row.closeRateSnapshotPct}%</strong>
                    <span>Close Rate</span>
                  </div>
                  <div>
                    <strong>{row.coverageLabel === "no cost data" || row.coverageLabel === "no data" ? "—" : `${row.marginPct.toFixed(0)}%`}</strong>
                    <span>Margin · {row.coverageLabel}</span>
                  </div>
                  <div>
                    <strong>{formatCurrency(row.arValue)}</strong>
                    <span>AR</span>
                  </div>
                </span>
                <span class="epl-bar" title={`${row.marginPct.toFixed(0)}% margin`}>
                  <span class="epl-bar-fill" style={`width:${Math.max(0, Math.min(100, row.marginPct))}%`} />
                </span>
              </summary>
              <div class="epl-location-body">
                <div class="epl-jobs-table-wrap" data-jobs-wrap data-account-key={row.accountKey}>
                  <p class="epl-jobs-loading" data-jobs-placeholder>Expand to load jobs&hellip;</p>
                </div>
              </div>
            </details>
          ))
        }
      </div>
    </section>
  </section>

  <script type="application/json" id="dashboard-data" set:html={JSON.stringify(dashboard)} />
  <script type="application/json" id="dashboard-config" set:html={JSON.stringify({ acculynxJobBaseUrl: ACCULYNX_JOB_BASE_URL })} />
  <script src="/src/scripts/executive-pipeline.ts"></script>
</AppShell>

<style>
  .epl {
    display: block;
  }
</style>
