---
import DepartmentDetail from "../../components/live/DepartmentDetail.astro";
import { loadDepartmentSurface } from "@lib/live-work";

const slug = Astro.params.slug ?? "pipeline";
const surface = await loadDepartmentSurface("executive");
const title = slug === "pipeline" ? "Executive Pipeline" : "Executive Detail";
---

<DepartmentDetail
  surface={surface}
  routePath={`/executive/${slug}`}
  routeTitle={title}
  routeDescription="Executive readout filtered to the source-backed constraint path Chris opened."
/>
