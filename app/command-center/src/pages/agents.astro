---
import AppShell from "../layouts/AppShell.astro";
import LiveMetricGrid from "../components/live/LiveMetricGrid.astro";
import { AGENT_AUTH_SOURCE, buildAuthorizationServerMetadata } from "@lib/agent-auth";
import { SERVICE_AGENT_IDENTITIES, getAgentAccessRuntimeConfig } from "@lib/access-control";
import { loadDepartmentSurface } from "@lib/live-work";

const surface = await loadDepartmentSurface("system");
const authConfig = getAgentAccessRuntimeConfig();
const metadata = buildAuthorizationServerMetadata();
const authRows = [
  { label: "Issuer", value: metadata.issuer },
  { label: "Register", value: metadata.agent_auth.register_uri },
  { label: "Claim", value: metadata.agent_auth.claim_uri },
  { label: "Token", value: metadata.token_endpoint },
  { label: "Revoke", value: metadata.agent_auth.revocation_uri },
];
---

<AppShell title="Agent Monitor" eyebrow="Live Runtime" activePage="agents" surface={surface}>
  <section class="live-department-hero" aria-label="Agent runtime summary">
    <div class="surface-heading">
      <div>
        <p class="eyebrow">Conductor / Auditor</p>
        <h2>Agent visibility from live workflow, sync, and auth state.</h2>
      </div>
      <div class="surface-meta">
        <span class="runtime-pill" data-tone={surface.status === "live" ? "ready" : "watch"}>
          <span class="signal-dot" aria-hidden="true"></span>
          {surface.status}
        </span>
      </div>
    </div>
    <LiveMetricGrid metrics={surface.metrics} />
  </section>

  <section class="monitor-grid" aria-label="Agent runtime monitor">
    <div class="agent-table-panel">
      <div class="panel-heading">
        <h2>Agent Access</h2>
        <span class="runtime-pill" data-tone={authConfig.serviceAuthConfigured ? "ready" : "blocked"}>
          <span class="signal-dot" aria-hidden="true"></span>
          {authConfig.serviceTokenCount} service tokens
        </span>
      </div>

      <div class="queue-table-wrap">
        <table class="queue-table">
          <thead>
            <tr>
              <th scope="col">Agent</th>
              <th scope="col">Role</th>
              <th scope="col">Department Access</th>
              <th scope="col">Open Items</th>
            </tr>
          </thead>
          <tbody>
            {
              SERVICE_AGENT_IDENTITIES.map((agent) => {
                const access = agent.departmentAccess === "all" ? "all" : agent.departmentAccess.join(", ");
                const openItems =
                  agent.departmentAccess === "all"
                    ? surface.items.length
                    : surface.items.filter((item) => agent.departmentAccess.includes(item.department)).length;
                return (
                  <tr>
                    <td>
                      <strong>{agent.displayName}</strong>
                      <span>{agent.handle}</span>
                    </td>
                    <td>{agent.roles.join(", ")}</td>
                    <td>{access}</td>
                    <td>{openItems}</td>
                  </tr>
                );
              })
            }
          </tbody>
        </table>
      </div>
    </div>

    <aside class="auth-panel" aria-label="Agent authentication posture">
      <div class="panel-heading">
        <h2>Agent Auth</h2>
        <span class="runtime-pill" data-tone="watch">
          <span class="signal-dot" aria-hidden="true"></span>
          Discovery
        </span>
      </div>

      <dl class="auth-list">
        {
          authRows.map((row) => (
            <div>
              <dt>{row.label}</dt>
              <dd>{row.value}</dd>
            </div>
          ))
        }
      </dl>

      <div class="auth-foot">
        <span>{AGENT_AUTH_SOURCE.version}</span>
        <span>{AGENT_AUTH_SOURCE.dated}</span>
        <span>{authConfig.namedAgentCount} named agents</span>
      </div>
    </aside>
  </section>
</AppShell>
