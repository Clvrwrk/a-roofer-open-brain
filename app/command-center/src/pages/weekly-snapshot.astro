---
import AppShell from "../layouts/AppShell.astro";
import { loadWeeklySnapshot, type SnapshotMetric, type SnapshotRecord, type SnapshotRow } from "@lib/weekly-snapshot";

const snapshot = await loadWeeklySnapshot();
const generatedAt = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
  month: "short",
}).format(new Date(snapshot.generatedAt));

const sectionGroups = [
  {
    id: "new-leads",
    title: "New Leads",
    kicker: "Created in the snapshot window",
    icon: "L",
    rows: snapshot.sections.newLeads,
  },
  {
    id: "jobs-sold",
    title: "Jobs Sold",
    kicker: "Approved, won, or moved into production",
    icon: "$",
    rows: snapshot.sections.jobsSold,
  },
  {
    id: "sales",
    title: "Sales Leaderboard",
    kicker: "All locations",
    icon: "#",
    rows: snapshot.sections.salesLeaderboard,
  },
  {
    id: "accounts-receivable",
    title: "Accounts Receivable",
    kicker: "Open balances from mirrored job metadata",
    icon: "AR",
    rows: snapshot.sections.accountsReceivable,
  },
  {
    id: "claims",
    title: "Insurance Claims",
    kicker: "Claims and supplements in motion",
    icon: "IC",
    rows: snapshot.sections.claims,
  },
  {
    id: "activity",
    title: "Activity",
    kicker: "All locations, lifetime atoms in this window",
    icon: "A",
    rows: snapshot.sections.activity,
  },
];

function asData(records: SnapshotRecord[]) {
  return JSON.stringify(records);
}

function emptyRow(title: string): SnapshotRow {
  return {
    id: `empty-${title.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`,
    label: "No live records in this window",
    value: "0",
    secondary: "Waiting on live bridge data",
    href: "/weekly-snapshot#snapshot-dashboard",
    records: [],
  };
}

function rowList(rows: SnapshotRow[], title: string) {
  return rows.length > 0 ? rows : [emptyRow(title)];
}

const dashboardSeed =
  [...snapshot.metrics, ...sectionGroups.flatMap((group) => rowList(group.rows, group.title))].find((item) => item.records.length > 0) ??
  snapshot.metrics[0];
const seedRecords = dashboardSeed?.records ?? [];
const seedTitle = dashboardSeed?.label ?? "Weekly Snapshot";
const seedValue = "value" in dashboardSeed ? dashboardSeed.value : "";
const seedCaption = "caption" in dashboardSeed ? (dashboardSeed as SnapshotMetric).caption : "Filtered dashboard";

function metricClass(metric: SnapshotMetric) {
  return `snapshot-metric metric-${metric.tone}`;
}
---

<AppShell title="Weekly Snapshot" eyebrow="AccuLynx + Open Brain" activePage="snapshot">
  <section class="snapshot-hero" aria-label="Weekly snapshot summary">
    <div>
      <p class="eyebrow">Two-Week Snapshot</p>
      <h2>Clickable operating snapshot for every location, rep, and claim path.</h2>
    </div>
    <div class="snapshot-health" aria-label="Snapshot source health">
      {
        snapshot.health.map((source) => (
          <span class="snapshot-source" data-source-status={source.status}>
            <strong>{source.label}</strong>
            <span>{source.detail}</span>
          </span>
        ))
      }
    </div>
  </section>

  {
    snapshot.errors.length > 0 && (
      <div class="snapshot-alert" role="status">
        {snapshot.errors.join(" ")}
      </div>
    )
  }

  <section class="snapshot-layout" aria-label="Interactive weekly snapshot">
    <article class="snapshot-report" aria-label="Snapshot report">
      <header class="snapshot-report-head">
        <span class="snapshot-brand">Pro Exteriors Open Brain</span>
        <h2>Two-Week Snapshot</h2>
        <p>{snapshot.window.label}</p>
        <small>Generated {generatedAt}</small>
      </header>

      <div class="snapshot-metric-grid" aria-label="Topline metrics">
        {
          snapshot.metrics.map((metric) => (
            <a
              class={metricClass(metric)}
              href={metric.href}
              data-drilldown
              data-title={metric.label}
              data-value={metric.value}
              data-caption={metric.caption}
              data-records={asData(metric.records)}
            >
              <span class="metric-icon" aria-hidden="true">{metric.label.charAt(0)}</span>
              <strong>{metric.label}</strong>
              <small>{metric.caption}</small>
              <b>{metric.value}</b>
            </a>
          ))
        }
      </div>

      {
        sectionGroups.map((group) => (
          <section class="snapshot-section" data-section-kind={group.id}>
            <div class="snapshot-section-head">
              <span aria-hidden="true">{group.icon}</span>
              <div>
                <h3>{group.title}</h3>
                <p>{group.kicker}</p>
              </div>
            </div>

            <div class:list={["snapshot-list", group.id === "activity" && "snapshot-activity-list"]}>
              {
                rowList(group.rows, group.title).map((row) => (
                  <a
                    class="snapshot-row"
                    href={row.href}
                    data-drilldown
                    data-title={row.label}
                    data-value={row.value}
                    data-caption={`${group.title} / ${row.secondary}`}
                    data-records={asData(row.records)}
                  >
                    {row.rank && <span class="snapshot-rank">{row.rank}</span>}
                    <span class="snapshot-row-label">{row.label}</span>
                    <span class="snapshot-row-value">{row.value}</span>
                    <small>{row.secondary}</small>
                  </a>
                ))
              }
            </div>
          </section>
        ))
      }
    </article>

    <aside class="snapshot-dashboard" id="snapshot-dashboard" aria-label="Active dashboard drilldown">
      <div class="snapshot-dashboard-head">
        <p class="eyebrow">Active Dashboard</p>
        <h2 data-dashboard-title>{seedTitle}</h2>
        <strong data-dashboard-value>{seedValue}</strong>
        <span data-dashboard-caption>{seedCaption}</span>
        <a class="snapshot-dashboard-link" href={dashboardSeed?.href ?? "/weekly-snapshot#snapshot-dashboard"} data-dashboard-link>
          Open filtered dashboard view
        </a>
      </div>

      <div class="snapshot-record-count">
        <strong data-dashboard-count>{seedRecords.length}</strong>
        <span>records in the selected slice</span>
      </div>

      <div class="snapshot-record-table-wrap">
        <table class="snapshot-record-table">
          <thead>
            <tr>
              <th scope="col">Type</th>
              <th scope="col">Record</th>
              <th scope="col">Value</th>
              <th scope="col">Status</th>
            </tr>
          </thead>
          <tbody data-dashboard-rows>
            {
              seedRecords.length > 0 ? (
                seedRecords.map((record) => (
                  <tr>
                    <td>{record.type}</td>
                    <td>
                      <a href={record.href}>{record.label}</a>
                      <span>{record.sublabel}</span>
                    </td>
                    <td>{record.value}</td>
                    <td>{record.status}</td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td colspan="4">No records are available for this slice yet.</td>
                </tr>
              )
            }
          </tbody>
        </table>
      </div>

      <div class="snapshot-dashboard-note">
        <strong>Bridge contract</strong>
        <span>
          Supabase mirrors are canonical for this page. Missing sources render as empty live states with source health, never as copied email numbers.
        </span>
      </div>
    </aside>
  </section>

  <script src="/src/scripts/weekly-snapshot.ts"></script>
</AppShell>
