---
import AppShell from "../../../layouts/AppShell.astro";
import { loadPriceListReview } from "@lib/price-list-review";

const data = await loadPriceListReview();
const money = (n: number) => "$" + n.toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const payload = JSON.stringify({ docs: data.docs }).replace(/</g, "\\u003c");
---

<AppShell title="Price List Review" eyebrow="Accounting" activePage="pricing">
  <section class="plr">
    <p class="plr-lead">Family-level price lists with no item codes are matched to an item id# by description.
      Confirm or correct each match, then promote the list to a live agreement. Only <b>confirmed</b> + <b>high</b> rows promote.</p>

    {data.docs.length === 0 && <p class="plr-empty">No staged price lists.</p>}

    {data.docs.map((d) => (
      <details class="plr-doc" data-doc={d.sourceDoc} open>
        <summary>
          <span class="plr-doc-name">{d.office || d.sourceDoc} · #{d.branchNumber} · eff {d.effectiveDate}</span>
          <span class="plr-doc-tags">
            <span class="pill pill-grey">{d.counts.total} items</span>
            <span class="pill pill-green">{d.counts.high} high</span>
            <span class="pill pill-orange">{d.counts.review} review</span>
            <span class="pill pill-red">{d.counts.none} none</span>
            {d.counts.promoted > 0 && <span class="pill pill-purple">{d.counts.promoted} promoted</span>}
            <button class="plr-promote" data-promote={d.sourceDoc}>Promote → agreement</button>
          </span>
        </summary>
        <table class="plr-table">
          <thead><tr><th>Price-list description</th><th class="num">Price</th><th>UOM</th><th>Matched item id</th><th>Matched family</th><th class="num">Score</th><th>Status</th><th>Action</th></tr></thead>
          <tbody>
            {d.rows.map((r) => (
              <tr data-row={r.id} data-status={r.matchStatus}>
                <td>{r.rawDescription}</td>
                <td class="num">{money(r.price)}</td>
                <td>{r.uom}</td>
                <td><input class="plr-item" value={r.matchedItemNumber} data-id={r.id} placeholder="item #" /></td>
                <td class="plr-fam">{r.matchedFamily}</td>
                <td class="num">{r.matchScore.toFixed(2)}</td>
                <td><span class={`pill plr-stat plr-${r.matchStatus}`}>{r.matchStatus}</span></td>
                <td class="plr-actions">
                  <button class="plr-ok" data-confirm={r.id} title="Confirm">✓</button>
                  <button class="plr-no" data-reject={r.id} title="Reject">✕</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </details>
    ))}
  </section>

  <script id="plr-data" type="application/json" set:html={payload}></script>
  <script src="../../../scripts/price-list-review.ts"></script>
</AppShell>

<style is:global>
  .plr{--bg:#f4f6f9;--panel:#fff;--ink:#1c2733;--muted:#6b7886;--line:#e3e8ef;padding:4px 2px;color:var(--ink)}
  @media (prefers-color-scheme: dark){ .plr{--bg:#0f141b;--panel:#161d27;--ink:#e6edf5;--muted:#8b98a8;--line:#27313e} }
  .plr-lead{color:var(--muted);font-size:13px;margin:0 0 16px}
  .plr-empty{color:var(--muted)}
  .plr-doc{background:var(--panel);border:1px solid var(--line);border-radius:14px;margin-bottom:14px;padding:4px 14px 12px}
  .plr-doc>summary{display:flex;align-items:center;justify-content:space-between;gap:12px;cursor:pointer;padding:12px 2px;list-style:none}
  .plr-doc-name{font-weight:650}
  .plr-doc-tags{display:flex;align-items:center;gap:8px}
  .plr .pill{display:inline-block;font-size:11px;font-weight:600;padding:2px 8px;border-radius:8px}
  .plr .pill-grey{background:rgba(140,150,170,.16);color:#8a93a6} .plr .pill-green{background:rgba(46,158,91,.16);color:#2e9e5b}
  .plr .pill-orange{background:rgba(208,138,29,.16);color:#d08a1d} .plr .pill-red{background:rgba(208,73,75,.16);color:#d0494b}
  .plr .pill-purple{background:rgba(147,112,219,.18);color:#9370db}
  .plr-promote{background:#9370db;color:#fff;border:none;border-radius:9px;padding:6px 12px;font-weight:650;font-size:12px;cursor:pointer}
  .plr-promote:hover{filter:brightness(1.08)} .plr-promote:disabled{opacity:.5;cursor:default}
  .plr-table{width:100%;border-collapse:collapse;font-size:12.5px;margin-top:6px}
  .plr-table th{text-align:left;color:var(--muted);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:.03em;padding:6px 8px;border-bottom:1px solid var(--line)}
  .plr-table td{padding:5px 8px;border-bottom:1px solid var(--line);color:var(--ink)} .plr-table .num{text-align:right;font-variant-numeric:tabular-nums}
  .plr-fam{color:var(--muted)}
  .plr-item{width:120px;background:var(--bg);border:1px solid var(--line);border-radius:6px;color:var(--ink);padding:3px 6px;font-size:12px}
  .plr-stat.plr-high{background:rgba(46,158,91,.16);color:#2e9e5b} .plr-stat.plr-review{background:rgba(208,138,29,.16);color:#d08a1d}
  .plr-stat.plr-none{background:rgba(208,73,75,.16);color:#d0494b} .plr-stat.plr-confirmed{background:rgba(46,158,91,.28);color:#2e9e5b}
  .plr-stat.plr-rejected{background:rgba(140,150,170,.16);color:#8a93a6} .plr-stat.plr-promoted{background:rgba(147,112,219,.18);color:#9370db}
  .plr-actions{white-space:nowrap}
  .plr-ok,.plr-no{border:none;border-radius:6px;width:26px;height:24px;cursor:pointer;font-weight:700;margin-right:4px}
  .plr-ok{background:rgba(46,158,91,.18);color:#2e9e5b} .plr-no{background:rgba(208,73,75,.16);color:#d0494b}
  tr[data-status="rejected"]{opacity:.5} tr[data-status="promoted"]{opacity:.6}
</style>
