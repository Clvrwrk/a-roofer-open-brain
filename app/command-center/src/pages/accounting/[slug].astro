---
import BoundaryNotice from "../../components/accounting/BoundaryNotice.astro";
import EvidenceStack from "../../components/accounting/EvidenceStack.astro";
import MetricLinkCard from "../../components/accounting/MetricLinkCard.astro";
import AppShell from "../../layouts/AppShell.astro";
import HumanUnblockerDashboard from "../../components/unblocker/HumanUnblockerDashboard.astro";
import {
  formatCurrency,
  formatNumber,
  getAccountingDashboard,
  loadAccountingSurface,
  type CreditMemoCandidate,
  type InvoiceGateCandidate,
} from "@lib/accounting-dashboard";
import type { AgreementGapRow } from "@lib/abc-price-gaps";
import { loadDepartmentSurface } from "@lib/live-work";
import { loadVendorTerritorySurface } from "@lib/vendor-territories";

const slug = Astro.params.slug;
const dashboard = getAccountingDashboard(slug);

if (!dashboard) {
  Astro.response.status = 404;
}

const surface = await loadAccountingSurface();
const liveSurface = await loadDepartmentSurface("accounting");
const territorySurface = dashboard?.slug === "vendor-regions" ? await loadVendorTerritorySurface() : null;
const reviewQueueItems = liveSurface.items.filter((item) => item.workflow === "abc-review");
const routeLiveItems = dashboard
  ? liveSurface.items.filter((item) => {
      const itemRoute = item.href.split("?")[0];
      return itemRoute === dashboard.route || item.href.startsWith(`${dashboard.route}?`);
    })
  : [];
const selectedReviewItemId = Astro.url.searchParams.get("item");
const selectedReviewItem = selectedReviewItemId
  ? reviewQueueItems.find((item) => item.sourcePk === selectedReviewItemId)
  : null;
const generatedAt = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
  month: "short",
}).format(new Date(surface.generatedAt));
const pageTitle = dashboard?.title ?? "Accounting dashboard not found";

function hasReason(row: AgreementGapRow, code: string) {
  return row.gapReasons.some((reason) => reason.code === code);
}

function needsAgreementEvidence(row: AgreementGapRow) {
  return row.evidenceStatus !== "pdf_mapped";
}

function lineMismatchSummary(row: AgreementGapRow) {
  const parts = [
    row.gapReasons.map((reason) => reason.label).join(", "),
    row.variance !== null ? `Variance ${formatCurrency(row.variance)} per ${row.invoiceUom}` : null,
    row.referencePrice === null ? "No trusted reference price" : null,
  ].filter(Boolean);
  return parts.join(" / ") || row.evidenceStatusLabel;
}

function sourceRowHref(href: string) {
  return `${href.split("#")[0]}#source-row-detail`;
}

function priceAuthorityLabel(row: AgreementGapRow) {
  if (row.evidenceStatus === "pdf_mapped") return "PDF agreement authority";
  if (row.evidenceStatus === "no_pdf_api_match") return "API pricing matches invoice; Lucinda can approve a temporary rule.";
  if (row.evidenceStatus === "no_pdf_api_mismatch") return "API pricing conflicts with invoice; keep blocked.";
  if (row.evidenceStatus === "no_pdf_api_missing") return "API did not return a usable branch/SKU price.";
  if (row.evidenceStatus === "no_price_line") return "Product identity or branch/SKU price line is missing.";
  return "No trusted branch/region pricing authority.";
}

function primaryLineDecision(row: AgreementGapRow) {
  if (row.evidenceStatus === "no_pdf_api_match") {
    return {
      decision: "approve",
      intent: "approve_api_temporary_price_rule",
      label: "Approve API temp rule",
      nextStep:
        "Record the API match as a temporary observation-backed price rule, send Roberto the FYI acknowledgement task, roll the approved branch price into products, and suppress this SKU/branch until source changes or agreement expiry.",
      tone: "secondary",
    };
  }

  if (row.evidenceStatus === "no_pdf_api_mismatch") {
    return {
      decision: "needs_more_evidence",
      intent: "request_credit_memo_or_vendor_price_evidence",
      label: "Request evidence",
      nextStep:
        "Keep the invoice blocked. Agent drafts Lucinda's vendor evidence or credit-memo request with invoice PDF, original order, API price, and last known agreement attached.",
      tone: "primary",
    };
  }

  return {
    decision: "needs_more_evidence",
    intent: "request_price_agreement_source_file",
    label: "Request agreement",
    nextStep:
      "Keep the invoice blocked. Agent drafts Lucinda's price-agreement request to the rep and includes the invoice PDF, original order, SKU, branch, and current evidence packet.",
    tone: "primary",
  };
}

function lineActionClass(tone: string) {
  if (tone === "primary") return "button button-primary";
  if (tone === "ghost") return "button button-ghost";
  return "button button-secondary";
}

const productRows = surface.gapRows.filter((row) => hasReason(row, "no_price_list_item") || hasReason(row, "uom_mismatch"));
const branchRows = surface.gapRows.filter((row) => hasReason(row, "no_branch_agreement") || hasReason(row, "no_fixed_agreement"));
const apiEvidenceRows = surface.gapRows.filter((row) =>
  ["no_pdf_api_match", "no_pdf_api_mismatch", "no_pdf_api_missing"].includes(row.evidenceStatus),
);
const apiEvidenceRowIds = new Set(apiEvidenceRows.map((row) => row.id));
const visibleGapRows = [...apiEvidenceRows, ...surface.gapRows.filter((row) => !apiEvidenceRowIds.has(row.id))].slice(0, 100);
const requestedInvoice = Astro.url.searchParams.get("invoice");
const selectedInvoiceCandidate = dashboard?.slug === "invoices"
  ? requestedInvoice
    ? surface.invoiceGateCandidates.find((invoice) => invoice.invoiceNumber === requestedInvoice) ?? null
    : surface.invoiceGateCandidates[0] ?? null
  : null;
const selectedInvoice = selectedInvoiceCandidate?.invoiceNumber ?? requestedInvoice;
const selectedInvoiceRows = selectedInvoiceCandidate?.lines ?? (selectedInvoice ? surface.gapRows.filter((row) => row.invoiceNumber === selectedInvoice) : []);
const selectedInvoiceExceptionRows = selectedInvoiceRows.filter(needsAgreementEvidence);
const invoiceQueueCandidates = selectedInvoiceCandidate
  ? [selectedInvoiceCandidate, ...surface.invoiceGateCandidates.filter((invoice) => invoice.invoiceNumber !== selectedInvoiceCandidate.invoiceNumber)]
  : surface.invoiceGateCandidates;
const branchGroups = Array.from(
  branchRows.reduce((groups, row) => {
    const key = row.branchNumber || "Unknown";
    const current = groups.get(key) ?? {
      branchNumber: key,
      branchName: row.branchName,
      rows: 0,
      invoices: new Set<string>(),
      reasons: new Set<string>(),
    };
    current.rows += 1;
    current.invoices.add(row.invoiceNumber);
    for (const reason of row.gapReasons) current.reasons.add(reason.label);
    groups.set(key, current);
    return groups;
  }, new Map<string, { branchNumber: string; branchName: string; rows: number; invoices: Set<string>; reasons: Set<string> }>()),
).map(([, value]) => value).sort((a, b) => b.rows - a.rows);

const boundaryTitle = "Live source boundary";
const boundaryDetail =
  "This route uses current Supabase mirrors and dashboard workflow tables. QuickBooks facts remain Lucinda-controlled and are recorded only after Lucinda confirms them.";
---

<AppShell title={pageTitle} eyebrow="Accounting Dashboard" activePage="accounting">
  {
    dashboard ? (
      <>
        {dashboard.slug !== "invoices" && (
          <section class="accounting-hero" aria-label={`${dashboard.title} summary`}>
            <div class="surface-heading">
              <div>
                <p class="eyebrow">{dashboard.owner}</p>
                <h2>{dashboard.description}</h2>
              </div>
              <div class="surface-meta">
                <span class="runtime-pill" data-tone={dashboard.readiness === "live" ? "ready" : "watch"}>
                  <span class="signal-dot" aria-hidden="true"></span>
                  {dashboard.readiness.replace("-", " ")}
                </span>
                <span>{generatedAt}</span>
              </div>
            </div>

            <div class="accounting-metric-grid">
              <MetricLinkCard
                label="Gap rows"
                value={formatNumber(surface.metrics.gapRows)}
                caption={`${formatNumber(surface.metrics.criticalRows)} critical`}
                href="/accounting/price-agreement-gaps"
                tone={surface.metrics.criticalRows > 0 ? "critical" : "info"}
              />
              <MetricLinkCard
                label="Expected credit"
                value={formatCurrency(surface.metrics.expectedCredit)}
                caption={`${formatNumber(surface.creditMemoCandidates.length)} candidate packets`}
                href="/accounting/credit-memos"
                tone="review"
              />
              <MetricLinkCard
                label="Invoice gate"
                value={formatNumber(surface.invoiceGateCandidates.length)}
                caption={`${formatNumber(surface.metrics.openInvoices)} unpaid/open`}
                href="/accounting/invoices"
                tone="critical"
              />
              <MetricLinkCard
                label="Workflow state"
                value={dashboard.readiness.replace("-", " ")}
                caption={dashboard.source}
                href={dashboard.route}
                tone={dashboard.readiness === "live" ? "ready" : "info"}
              />
            </div>
          </section>
        )}

        {dashboard.slug === "invoices" && (
          <section class="invoice-gate-workbench" aria-label="Invoice payment gate workbench">
            <div class="invoice-workbench-heading">
              <div>
                <p class="eyebrow">Lucinda Invoice Gate</p>
                <h2>Fix the selected unpaid invoice exception first.</h2>
                <p>
                  Paid invoices are excluded. This surface only shows the line items that are out of tolerance, missing a trusted
                  price authority, or need Lucinda to approve the next agent move.
                </p>
              </div>
              <div class="invoice-workbench-count">
                <strong>{formatNumber(surface.invoiceGateCandidates.length)}</strong>
                <span>unpaid invoices with blockers</span>
              </div>
            </div>

            {surface.invoiceGateCandidates.length > 0 ? (
              <div class="invoice-gate-layout">
                <aside class="invoice-queue-rail" aria-label="Unpaid invoice queue">
                  <div class="invoice-queue-rail-heading">
                    <p class="eyebrow">Queue</p>
                    <h3>Review only exceptions</h3>
                  </div>
                  <div class="invoice-queue-list">
                    {invoiceQueueCandidates.map((invoice: InvoiceGateCandidate) => (
                      <a
                        class:list={["invoice-queue-item", selectedInvoice === invoice.invoiceNumber && "is-selected"]}
                        href={invoice.href}
                        aria-current={selectedInvoice === invoice.invoiceNumber ? "page" : undefined}
                      >
                        <span class="invoice-queue-main">
                          <strong>{invoice.invoiceNumber}</strong>
                          <span>{invoice.vendor}</span>
                        </span>
                        <span class="invoice-queue-meta">
                          <span>{invoice.acculynxJobNumber}</span>
                          <span>{formatNumber(invoice.missingAgreementLineCount)} blocked lines</span>
                        </span>
                      </a>
                    ))}
                  </div>
                </aside>

                <section class="invoice-repair-surface" aria-label="Selected invoice repair task">
                  {selectedInvoiceCandidate ? (
                    <>
                      <div class="invoice-repair-heading">
                        <div>
                          <p class="eyebrow">Human Answer Needed</p>
                          <h2>{selectedInvoiceCandidate.vendor} / {selectedInvoiceCandidate.invoiceNumber}</h2>
                          <p>
                            Decide whether each exception can be released by API pricing, needs an official price line, or must stay
                            blocked while Lucinda requests source evidence.
                          </p>
                        </div>
                        <span class={`status-badge priority-${selectedInvoiceCandidate.criticalRows > 0 ? "critical" : selectedInvoiceCandidate.blockedRows > 0 ? "high" : "normal"}`}>
                          {selectedInvoiceCandidate.primaryAction}
                        </span>
                      </div>

                      <div class="invoice-fact-grid" aria-label="Invoice facts">
                        <div>
                          <span>AccuLynx Job #</span>
                          <strong>{selectedInvoiceCandidate.acculynxJobNumber}</strong>
                        </div>
                        <div>
                          <span>Payment state</span>
                          <strong>{selectedInvoiceCandidate.paymentStatus}</strong>
                        </div>
                        <div>
                          <span>Lines needing review</span>
                          <strong>{formatNumber(selectedInvoiceExceptionRows.length)} of {formatNumber(selectedInvoiceCandidate.lineCount)}</strong>
                        </div>
                        <div>
                          <span>Expected credit exposure</span>
                          <strong>{formatCurrency(selectedInvoiceCandidate.expectedCredit || selectedInvoiceCandidate.absoluteVariance)}</strong>
                        </div>
                      </div>

                      <div class="invoice-evidence-board" aria-label="Current evidence">
                        <div>
                          <span>Invoice PDF</span>
                          <strong>{selectedInvoiceCandidate.invoiceEvidenceLabel}</strong>
                        </div>
                        <div>
                          <span>Last known agreement</span>
                          <strong>{selectedInvoiceCandidate.agreementEvidenceLabel}</strong>
                        </div>
                      </div>

                      <div class="invoice-line-card-list">
                        {selectedInvoiceExceptionRows.map((line) => {
                          const action = primaryLineDecision(line);
                          return (
                            <article class="invoice-line-card" data-decision-context>
                              <header>
                                <div>
                                  <p class="eyebrow">Line {line.lineNumber}</p>
                                  <h3>{line.itemNumber}</h3>
                                  <p>{line.itemDescription}</p>
                                </div>
                                <span class={`status-badge gap-${line.severity}`}>{line.severity}</span>
                              </header>

                              <div class="human-answer-callout">
                                <span>Lucinda needs to decide</span>
                                <strong>{line.humanAction}</strong>
                              </div>

                              <div class="line-evidence-grid">
                                <div>
                                  <span>What does not match</span>
                                  <strong>{lineMismatchSummary(line)}</strong>
                                </div>
                                <div>
                                  <span>Invoice line</span>
                                  <strong>{formatCurrency(line.invoicePrice)} / {line.quantity ?? "qty missing"} {line.invoiceUom}</strong>
                                </div>
                                <div>
                                  <span>Trusted reference</span>
                                  <strong>{line.referenceAgreement}</strong>
                                </div>
                                <div>
                                  <span>Branch / region</span>
                                  <strong>{line.branchNumber} / {line.branchRegion}</strong>
                                </div>
                                <div>
                                  <span>Authority state</span>
                                  <strong>{priceAuthorityLabel(line)}</strong>
                                </div>
                                <div>
                                  <span>Source evidence</span>
                                  <strong>{line.evidenceStatusLabel} / {line.agreementSource}</strong>
                                </div>
                              </div>

                              <div class="line-direct-entry">
                                <label>
                                  <span>Approved price</span>
                                  <input data-decision-field="approved price" type="number" name={`price-${line.id}`} inputmode="decimal" step="0.01" value={line.referencePrice ?? ""} />
                                </label>
                                <label>
                                  <span>UOM</span>
                                  <input data-decision-field="approved UOM" type="text" name={`uom-${line.id}`} value={line.invoiceUom === "Missing" ? "" : line.invoiceUom} />
                                </label>
                                <label>
                                  <span>Active start</span>
                                  <input data-decision-field="active start" type="date" name={`active-start-${line.id}`} />
                                </label>
                                <label>
                                  <span>Active end</span>
                                  <input data-decision-field="active end" type="date" name={`active-end-${line.id}`} />
                                </label>
                              </div>

                              <div class="line-evidence-actions">
                                <button
                                  class={lineActionClass(action.tone)}
                                  type="button"
                                  data-live-decision={action.decision}
                                  data-work-key={`accounting:price-gap:${line.id}`}
                                  data-action-intent={action.intent}
                                  data-action-label={action.label}
                                  data-action-next-step={action.nextStep}
                                >
                                  {action.label}
                                </button>
                                <button
                                  class="button button-secondary"
                                  type="button"
                                  data-live-decision="approve"
                                  data-work-key={`accounting:price-gap:${line.id}`}
                                  data-action-intent="create_official_price_agreement_line"
                                  data-action-label="Create official price line"
                                  data-action-next-step="Create or update the price agreement header and line item, map Vendor-branch-id / Branch Price / Branch UOM into products, send Roberto the FYI acknowledgement task, and require Lucinda to mark the price approved."
                                >
                                  Create official price line
                                </button>
                                <button
                                  class="button button-ghost"
                                  type="button"
                                  data-live-decision="needs_more_evidence"
                                  data-work-key={`accounting:price-gap:${line.id}`}
                                  data-action-intent="request_pdf_or_csv_price_agreement"
                                  data-action-label="Request PDF/CSV agreement"
                                  data-action-next-step="Agent drafts Lucinda's rep email requesting the PDF/CSV agreement and attaches the invoice PDF, original order, branch, SKU, and current API/pricing evidence. Agent does not send externally."
                                >
                                  Request PDF/CSV agreement
                                </button>
                              </div>
                            </article>
                          );
                        })}

                        {selectedInvoiceExceptionRows.length === 0 && (
                          <BoundaryNotice
                            title="No exception lines remain"
                            detail="This unpaid invoice has no line-level pricing blocker in the current Supabase gap surface."
                            action="Agent may re-check payment release prerequisites before Lucinda marks it ready."
                          />
                        )}
                      </div>
                    </>
                  ) : (
                    <BoundaryNotice
                      title={requestedInvoice ? "Invoice is not in the open unpaid exception queue" : "No unpaid invoice exception is open"}
                      detail={requestedInvoice ? `${requestedInvoice} may be paid, resolved, or missing from the current ABC mirror.` : "Paid invoices are treated as processed and hidden from this dashboard."}
                      action="Refresh the ABC invoice mirror or open Accounting audit log if this looks wrong."
                    />
                  )}
                </section>

                <aside class="invoice-guidance-panel" aria-label="Pricing flow guidance">
                  <p class="eyebrow">Pricing Source Of Truth</p>
                  <h3>Products becomes the final branch pricing catalog.</h3>
                  <dl>
                    <div>
                      <dt>PDF / CSV agreement</dt>
                      <dd>Create agreement header and parsed line items immediately, then map approved branch prices into products.</dd>
                    </div>
                    <div>
                      <dt>API pricing match</dt>
                      <dd>May unblock as API Pricing after Lucinda approves the temporary observation-backed rule.</dd>
                    </div>
                    <div>
                      <dt>Manual entry</dt>
                      <dd>Creates an official price-agreement line after Roberto acknowledges and Lucinda marks the price approved.</dd>
                    </div>
                    <div>
                      <dt>Suppression rule</dt>
                      <dd>A resolved SKU/branch should not reappear unless a new agreement is added or the current agreement expires.</dd>
                    </div>
                  </dl>
                  <label class="decision-note-label">
                    <span>Decision note</span>
                    <textarea data-decision-note rows="3" placeholder="Add Lucinda's answer, vendor context, or approval constraint"></textarea>
                  </label>
                  <p class="action-note" data-action-note>
                    Pick a line action to save the decision, entered price fields, and next agent step to Supabase.
                  </p>
                  <BoundaryNotice
                    title="Dashboard is source, Slack is mirror"
                    detail="These actions write to Supabase first. Slack mirrors the action ID and packet after the dashboard decision is accepted."
                    action="External vendor emails remain Lucinda-only."
                  />
                </aside>
              </div>
            ) : (
              <BoundaryNotice
                title="No unpaid invoice blockers"
                detail="The current live surface has no unpaid invoice rows that require price-agreement review."
                action="Open audit log if an expected invoice is missing."
              />
            )}
          </section>
        )}

        {dashboard.slug !== "invoices" && (
          <>
            <HumanUnblockerDashboard
              items={routeLiveItems.length > 0 ? routeLiveItems : liveSurface.items}
              department="accounting"
              emptyLabel="No live accounting blocker is open for this source path."
            />

        <details class="accounting-full-source-detail" open={Boolean(selectedReviewItemId || selectedInvoice)}>
          <summary>Full accounting source detail</summary>
          <section class="accounting-workbench" aria-label="Accounting dashboard workbench">
          <div class="accounting-priority-panel">
            <div class="panel-heading">
              <div>
                <p class="eyebrow">Decision Surface</p>
                <h2>{dashboard.decision}</h2>
              </div>
              <a class="row-action" href="/accounting">Accounting home</a>
            </div>

            {dashboard.slug === "review-queue" && (
              <div class="queue-table-wrap">
                <table class="queue-table accounting-table">
                  <thead>
                    <tr>
                      <th scope="col">Review item</th>
                      <th scope="col">Human</th>
                      <th scope="col">Priority</th>
                      <th scope="col">Evidence</th>
                      <th scope="col">Value</th>
                      <th scope="col">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {reviewQueueItems.map((item) => (
                      <tr class:list={[selectedReviewItemId === item.sourcePk && "is-selected"]}>
                        <td><strong>{item.title}</strong><span>{item.detail}</span></td>
                        <td>{item.primaryHuman}</td>
                        <td><span class={`status-badge priority-${item.priority}`}>{item.priority}</span></td>
                        <td>{item.evidence}</td>
                        <td><strong>{formatCurrency(item.valueAtRisk)}</strong></td>
                        <td><a class="row-action" href={sourceRowHref(item.href)}>Source detail</a></td>
                      </tr>
                    ))}
                    {reviewQueueItems.length === 0 && (
                      <tr>
                        <td colspan="6">No open ABC review rows are present in the live queue.</td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>
            )}

            {dashboard.slug === "price-agreement-gaps" && (
              <div class="queue-table-wrap">
                <table class="queue-table accounting-table accounting-gap-table">
                  <thead>
                    <tr>
                      <th scope="col">Invoice / SKU</th>
                      <th scope="col">Branch</th>
                      <th scope="col">Reason</th>
                      <th scope="col">Invoiced</th>
                      <th scope="col">Reference</th>
                      <th scope="col">Human action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {visibleGapRows.map((row) => (
                      <tr>
                        <td><strong>{row.invoiceNumber}</strong><span>{row.itemNumber} / {row.itemDescription}</span></td>
                        <td><strong>{row.branchNumber}</strong><span>{row.branchName}</span></td>
                        <td>
                          <span class={`status-badge gap-${row.severity}`}>{row.severity}</span>
                          <span>{row.gapReasons.map((reason) => reason.label).join(", ")}</span>
                          <small>{row.evidenceStatusLabel}</small>
                        </td>
                        <td><strong>{formatCurrency(row.invoicePrice)}</strong><span>{row.quantity ?? "Qty missing"} {row.invoiceUom}</span></td>
                        <td><span>{row.referenceAgreement}</span><small>{row.agreementSource}</small></td>
                        <td>{row.humanAction}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {dashboard.slug === "credit-memos" && (
              <div class="queue-table-wrap">
                <table class="queue-table accounting-table">
                  <thead>
                    <tr>
                      <th scope="col">Packet</th>
                      <th scope="col">Expected credit</th>
                      <th scope="col">Lines</th>
                      <th scope="col">Blockers</th>
                      <th scope="col">Status</th>
                      <th scope="col">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {surface.creditMemoCandidates.map((packet: CreditMemoCandidate) => (
                      <tr>
                        <td><strong>{packet.invoiceNumber}</strong><span>{packet.branchLabels.slice(0, 2).join(", ") || "No branch"}</span></td>
                        <td><strong>{formatCurrency(packet.expectedCredit)}</strong><span>{formatCurrency(packet.absoluteVariance)} absolute variance</span></td>
                        <td>{formatNumber(packet.lineCount)}</td>
                        <td><span>{packet.gapReasonLabels.slice(0, 3).join(", ") || "None"}</span></td>
                        <td><span class={`status-badge gap-${packet.severity}`}>{packet.severity}</span></td>
                        <td><a class="row-action" href={packet.href}>Open packet</a></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {dashboard.slug === "product-matches" && (
              <div class="queue-table-wrap">
                <table class="queue-table accounting-table">
                  <thead>
                    <tr>
                      <th scope="col">Invoice / SKU</th>
                      <th scope="col">Description</th>
                      <th scope="col">UOM</th>
                      <th scope="col">Reason</th>
                      <th scope="col">Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {productRows.map((row) => (
                      <tr>
                        <td><strong>{row.invoiceNumber}</strong><span>{row.itemNumber}</span></td>
                        <td>{row.itemDescription}</td>
                        <td>{row.invoiceUom}</td>
                        <td>{row.gapReasons.map((reason) => reason.label).join(", ")}</td>
                        <td>{row.humanAction}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {dashboard.slug === "vendor-regions" && (
              <div class="vendor-territory-stack">
                <section class="vendor-territory-panel" aria-label="Vendor territory coverage map">
                  <div class="vendor-territory-top">
                    <div class="vendor-logo-lockup">
                      <img src="/pro-exteriors-logo.svg" alt="Pro Exteriors" width="190" height="56" />
                      <div>
                        <p class="eyebrow">Vendor Territories</p>
                        <h3>Branch coverage by PE office drive-time territory</h3>
                      </div>
                    </div>
                    {territorySurface && (
                      <span class="runtime-pill" data-tone={territorySurface.status === "live" ? "ready" : "watch"}>
                        <span class="signal-dot" aria-hidden="true"></span>
                        {territorySurface.status}
                      </span>
                    )}
                  </div>

                  {territorySurface ? (
                    <>
                      <div class="territory-stat-grid" aria-label="Territory counts">
                        <div><strong>{formatNumber(territorySurface.counts.offices)}</strong><span>PE offices</span></div>
                        <div><strong>{formatNumber(territorySurface.counts.branches)}</strong><span>vendor branches</span></div>
                        <div><strong>{formatNumber(territorySurface.counts.pdfAgreementBranches)}</strong><span>PDF agreement</span></div>
                        <div><strong>{formatNumber(territorySurface.counts.apiOnlyBranches)}</strong><span>API only</span></div>
                        <div><strong>{formatNumber(territorySurface.counts.noPriceAgreementBranches)}</strong><span>no agreement</span></div>
                        <div><strong>{formatNumber(territorySurface.counts.needsDecision)}</strong><span>need decision</span></div>
                      </div>

                      {territorySurface.errors.length > 0 ? (
                        <BoundaryNotice
                          title="Territory map degraded"
                          detail={territorySurface.errors.join(" ")}
                          action="Refresh the Supabase territory mirror before using this page for branch decisions."
                        />
                      ) : (
                        <div class="vendor-map-shell">
                          <svg class="vendor-territory-map" viewBox="0 0 1000 620" role="img" aria-label="PE office territories and vendor branch coverage">
                            <rect x="0" y="0" width="1000" height="620" rx="18"></rect>
                            {territorySurface.offices.map((office) => (
                              <>
                                {office.polygonPoints && <polygon class="territory-boundary" points={office.polygonPoints}><title>{office.name} / {office.driveTimeMinutes ?? 120} minute drive-time</title></polygon>}
                              </>
                            ))}
                            {territorySurface.branches.map((branch) => (
                              <circle
                                class={`branch-pin pin-${branch.priceEvidenceStatus} route-${branch.status}${branch.pricingApproved ? " is-approved" : ""}`}
                                cx={branch.x}
                                cy={branch.y}
                                r={branch.status === "overlap_pending" ? "5.8" : branch.status === "out_of_boundary" ? "5.2" : "3.8"}
                              >
                                <title>{branch.vendorName} / {branch.branchNumber} {branch.branchName} / {branch.location} / {branch.priceEvidenceLabel} / {branch.status} / assigned: {branch.assignedOfficeName}</title>
                              </circle>
                            ))}
                            {territorySurface.offices.map((office) => (
                              office.x !== null && office.y !== null && (
                                <g class="office-marker">
                                  <circle cx={office.x} cy={office.y} r="8"></circle>
                                  <text x={office.x + 12} y={office.y + 4}>{office.name}</text>
                                </g>
                              )
                            ))}
                          </svg>
                          <div class="territory-legend" aria-label="Map legend">
                            <span><i class="pin-pdf_price_agreement"></i>PDF agreement</span>
                            <span><i class="pin-api_only_pricing"></i>API only</span>
                            <span><i class="pin-no_price_agreement"></i>No agreement</span>
                            <span><i class="route-overlap_pending"></i>Overlap ring</span>
                          </div>
                        </div>
                      )}

                      <div class="queue-table-wrap territory-review-table">
                        <table class="queue-table accounting-table">
                          <thead>
                            <tr>
                              <th scope="col">Branch</th>
                              <th scope="col">Status</th>
                              <th scope="col">Assigned / suggested</th>
                              <th scope="col">Candidates</th>
                              <th scope="col">Human answer</th>
                            </tr>
                          </thead>
                          <tbody>
                            {territorySurface.reviewBranches.slice(0, 40).map((branch) => (
                              <tr>
                                <td><strong>{branch.branchNumber} / {branch.branchName}</strong><span>{branch.vendorName} / {branch.location}</span></td>
                                <td>
                                  <span class={`territory-status status-${branch.status}`}>{branch.status.replace("_", " ")}</span>
                                  <span>{branch.priceEvidenceLabel}</span>
                                  <span>{branch.pricingApproved ? "pricing approved" : "pricing not approved"}</span>
                                </td>
                                <td><strong>{branch.assignedOfficeName}</strong><span>Suggested: {branch.suggestedOfficeName}</span></td>
                                <td>{formatNumber(branch.candidateOfficeCount)}</td>
                                <td>{branch.status === "overlap_pending" ? "Choose the default PE office/branch pricing path." : branch.status === "out_of_boundary" ? "Request branch-level price agreement evidence." : "Approve territory pricing evidence or request the missing source."}</td>
                              </tr>
                            ))}
                            {territorySurface.reviewBranches.length === 0 && (
                              <tr>
                                <td colspan="5">Every mapped vendor branch is covered and approved in the live territory surface.</td>
                              </tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                    </>
                  ) : (
                    <BoundaryNotice title="Territory surface not loaded" detail="This dashboard did not receive a vendor territory surface." action="Refresh /accounting/vendor-regions." />
                  )}
                </section>

                <div class="queue-table-wrap">
                  <table class="queue-table accounting-table">
                    <thead>
                      <tr>
                        <th scope="col">Branch</th>
                        <th scope="col">Rows</th>
                        <th scope="col">Invoices</th>
                        <th scope="col">Reasons</th>
                        <th scope="col">Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {branchGroups.map((branch) => (
                        <tr>
                          <td><strong>{branch.branchNumber}</strong><span>{branch.branchName}</span></td>
                          <td>{formatNumber(branch.rows)}</td>
                          <td>{formatNumber(branch.invoices.size)}</td>
                          <td>{Array.from(branch.reasons).slice(0, 3).join(", ")}</td>
                          <td>Approve mapping, flag exception, or escalate.</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {!["review-queue", "invoices", "price-agreement-gaps", "credit-memos", "product-matches", "vendor-regions"].includes(dashboard.slug) && (
              <div class="accounting-empty-workspace">
                <BoundaryNotice title={boundaryTitle} detail={boundaryDetail} action={dashboard.action} />
                <EvidenceStack
                  items={[
                    { label: "Human", value: dashboard.owner },
                    { label: "Decision", value: dashboard.decision },
                    { label: "Source boundary", value: dashboard.source },
                    { label: "Hidden by default", value: dashboard.hidden },
                  ]}
                />
              </div>
            )}
          </div>

          <aside class="accounting-decision-panel">
            <p class="eyebrow">Source Detail</p>
            <h2>{dashboard.action}</h2>
            <EvidenceStack
              items={[
                { label: "Owner", value: dashboard.owner },
                { label: "Readiness", value: dashboard.readiness.replace("-", " ") },
                { label: "Source", value: dashboard.source },
                { label: "Noise removed", value: dashboard.hidden },
              ]}
            />

            {selectedInvoiceRows.length > 0 && (
              <div class="reasoning-block">
                <h3>Selected invoice blockers</h3>
                <ul class="gap-reason-list">
                  {selectedInvoiceRows.slice(0, 8).map((row) => <li>{row.itemNumber}: {row.humanAction}</li>)}
                </ul>
              </div>
            )}

            {dashboard.slug === "review-queue" && selectedReviewItem && (
              <div class="reasoning-block source-row-detail" id="source-row-detail" tabindex="-1">
                <p class="eyebrow">Selected Source Row</p>
                <h3>{selectedReviewItem.title}</h3>
                <div class="source-answer-needed">
                  <strong>Answer needed</strong>
                  <span>Confirm the correct ABC branch/region/price agreement for this invoice, or identify the exact invoice/order/agreement evidence the agent must get before pricing can continue.</span>
                </div>
                <EvidenceStack
                  items={[
                    { label: "Evidence", value: selectedReviewItem.evidence },
                    { label: "Value at risk", value: formatCurrency(selectedReviewItem.valueAtRisk) },
                    { label: "Issue", value: selectedReviewItem.detail },
                    { label: "Action after answer", value: "Agent checks the confirmed price agreement, drafts a credit memo request if needed, or keeps the invoice blocked while Lucinda requests the missing agreement." },
                    { label: "Source row", value: `${selectedReviewItem.sourceTable} / ${selectedReviewItem.sourcePk}` },
                  ]}
                />
                <div class="audit-block">
                  <h3>Source facts</h3>
                  <ol>
                    {selectedReviewItem.auditTrail.map((entry) => <li>{entry}</li>)}
                  </ol>
                </div>
              </div>
            )}

            {dashboard.slug === "review-queue" && selectedReviewItemId && !selectedReviewItem && (
              <div class="reasoning-block source-row-detail" id="source-row-detail" tabindex="-1">
                <p class="eyebrow">Selected Source Row</p>
                <h3>Source row not in the open queue</h3>
                <p>
                  Item {selectedReviewItemId} is not present in the current unresolved ABC review queue surface. It may have
                  been resolved, dropped below the current priority window, or moved out of the live queue.
                </p>
              </div>
            )}

            <BoundaryNotice
              title="Dashboard is source, Slack is mirror"
              detail="Workflow actions should write to Supabase first. Slack uses the same packet/action IDs for fast review once the browser path is trusted."
            />
          </aside>
          </section>
        </details>
          </>
        )}
      </>
    ) : (
      <BoundaryNotice title="Dashboard not found" detail={`No Accounting dashboard exists for "${slug}".`} action="Return to /accounting." />
    )
  }
  <script src="/src/scripts/command-center.ts"></script>
</AppShell>
