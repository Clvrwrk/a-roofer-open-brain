---
import AppShell from "../../layouts/AppShell.astro";
import { loadInvoiceAudit } from "@lib/invoice-audit";

const data = await loadInvoiceAudit();
const generatedAt = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" }).format(new Date(data.generatedAt));
const runtimeTone = data.status === "live" ? "ready" : "watch";
const runtimeLabel = data.status === "live" ? "Supabase live" : "Supabase pending";
const offices = data.offices.map((o) => o.office);
const money = (n: number) => "$" + Math.round(n).toLocaleString("en-US");

// Disposition actions (unchanged from the prior invoice-audit spec).
const ACTIONS = [
  { id: "accept-neg", group: "accept", label: "Accept — Single Negotiated Terms", hint: "Add this price to observations as negotiated terms for this invoice only." },
  { id: "accept-tbn", group: "accept", label: 'Accept — Add to "To Be Negotiated"', hint: "Accept now; queue the item for the next vendor negotiation cycle." },
  { id: "accept-30d", group: "accept", label: "Accept — 30-Day Weekly Review", hint: "Accept now; re-surface in the weekly review queue for 30 days." },
  { id: "accept-nochallenge", group: "accept", label: 'Accept — "No Challenge" (always)', hint: "Whitelist this item price; stop flagging it going forward." },
  { id: "credit-flag", group: "credit", label: "Credit Memo + Flag Non-Payment", hint: "Generate credit-memo request AND hold the invoice from payment until resolved." },
  { id: "credit-noflag", group: "credit", label: "Credit Memo — Do Not Flag", hint: "Generate credit-memo request; invoice remains payable." },
];

const payload = JSON.stringify({ offices: data.offices, actions: ACTIONS, categories: data.categories }).replace(/</g, "\\u003c");
---

<AppShell title="Invoice Audit" eyebrow="Accounting" activePage="accounting">
  <section class="iv" data-theme="light" data-pref="system">
    <div class="iv-toolbar">
      <input class="iv-input" id="iv-search" type="search" placeholder="Search invoice, item, branch…" autocomplete="off" />
      <select class="iv-select" id="iv-office">
        <option value="">All PE offices</option>
        {offices.map((o) => <option value={o}>{o}</option>)}
      </select>
      <select class="iv-select" id="iv-status">
        <option value="open">Open invoices</option>
        <option value="paid">Paid (closed)</option>
        <option value="">All invoices</option>
      </select>
      <select class="iv-select" id="iv-tol">
        <option value="">All tolerance</option>
        <option value="0.01">Flagged ≥ Minor</option>
        <option value="3">Moderate +</option>
        <option value="6">Major only</option>
        <option value="noprice">No-Price lines</option>
      </select>
      <label class="iv-toggle"><input type="checkbox" id="iv-pending" checked /> To-audit only</label>
      <span class="iv-spacer"></span>
      <span class="runtime-pill" data-tone={runtimeTone}><span class="signal-dot" aria-hidden="true"></span>{runtimeLabel}</span>
      <span class="iv-count">{generatedAt}</span>
      <div class="iv-theme" role="group" aria-label="Theme">
        <button type="button" data-set-theme="system" class="is-active">System</button>
        <button type="button" data-set-theme="light">Light</button>
        <button type="button" data-set-theme="dark">Dark</button>
      </div>
    </div>

    <p class="iv-kpis-scope">KPIs below cover <strong>open (unpaid) invoices</strong> — the actionable set. Paid/closed are historical record (browse via the “All invoices” filter).</p>
    <div class="iv-kpis">
      <div class="iv-kpi"><span class="iv-kpi-lab">Open Invoices</span><span class="iv-kpi-val">{data.totals.openInvoices.toLocaleString()}</span><span class="iv-kpi-sub">active · {data.totals.paidInvoices} paid/closed</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">To Audit</span><span class="iv-kpi-val">{data.totals.pending.toLocaleString()}</span><span class="iv-kpi-sub">lines pending review</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">$ At Risk</span><span class="iv-kpi-val">{money(data.totals.atRisk)}</span><span class="iv-kpi-sub">un-audited overcharge vs negotiated</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">Credit Memo Requested</span><span class="iv-kpi-val">{money(data.totals.creditMemoRequested)}</span><span class="iv-kpi-sub">audited → credit-memo disposition</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">No-Price Lines</span><span class="iv-kpi-val">{data.totals.noPrice.toLocaleString()}</span><span class="iv-kpi-sub">no negotiated match</span></div>
      <div class="iv-kpi"><span class="iv-kpi-lab">Credit Memos</span><span class="iv-kpi-val">{data.totals.creditMemos.toLocaleString()}</span><span class="iv-kpi-sub">open · unapplied</span></div>
    </div>

    {data.totals.invoices === 0 && <p class="iv-empty">No invoices found in the live pipeline.</p>}
    <div id="iv-tree"></div>
  </section>

  <script type="application/json" id="iv-data" set:html={payload}></script>
  <div class="ia-toast" id="iv-toast" role="status" aria-live="polite"></div>
</AppShell>

<style is:global>
  .iv{
    --bg:#f4f6f9; --panel:#ffffff; --panel2:#f7f8fb; --ink:#1c2733; --muted:#6b7886; --line:#e3e8ef;
    --brand:#5b46d8; --brand-bg:#efecfd; --green:#137a4d; --green-bg:#e3f5ec; --yellow:#946400; --yellow-bg:#fbf0d4;
    --orange:#a4480d; --orange-bg:#fbe7d6; --red:#a51f1f; --red-bg:#fbe2e2; --grey:#5a6573; --grey-bg:#eceff4; --shadow:0 6px 18px rgba(20,28,40,.08);
    background:var(--bg); color:var(--ink);
    margin:calc(-1 * var(--space-4, 16px)) calc(-1 * var(--gutter, 24px)) calc(-1 * var(--space-6, 24px));
    padding:18px var(--gutter, 24px) 30px; min-height:70vh; font-family:var(--font-sans, Inter, system-ui, sans-serif);
  }
  .iv[data-theme="dark"]{
    --bg:#0f141b; --panel:#161d27; --panel2:#1c2530; --ink:#e6edf5; --muted:#8b98a8; --line:#27313e;
    --brand:#8a7bff; --brand-bg:#21243f; --green:#7ee2ad; --green-bg:#123626; --yellow:#f2cf6b; --yellow-bg:#3a3115;
    --orange:#f3a766; --orange-bg:#3d2913; --red:#ff8585; --red-bg:#3d1a1a; --grey:#9aa6b4; --grey-bg:#222c38; --shadow:0 6px 18px rgba(0,0,0,.4);
  }
  .iv .pill{display:inline-block;padding:2px 9px;border-radius:999px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.5}
  .iv .pill-green{background:var(--green-bg);color:var(--green)}
  .iv .pill-yellow{background:var(--yellow-bg);color:var(--yellow)}
  .iv .pill-orange{background:var(--orange-bg);color:var(--orange)}
  .iv .pill-red{background:var(--red-bg);color:var(--red)}
  .iv .pill-grey{background:var(--grey-bg);color:var(--grey)}
  .iv .pill-brand{background:var(--brand-bg);color:var(--brand)}

  .iv-toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px}
  .iv-input,.iv-select{background:var(--panel);border:1px solid var(--line);color:var(--ink);border-radius:8px;padding:8px 11px;font-size:13px;font-family:inherit}
  .iv-input{min-width:240px}
  .iv-spacer{flex:1}
  .iv-count{font-size:12px;color:var(--muted)}
  .iv-empty{color:var(--muted);font-size:13px;padding:14px 4px}
  .iv-theme{display:inline-flex;border:1px solid var(--line);border-radius:9px;overflow:hidden;background:var(--panel)}
  .iv-theme button{appearance:none;border:none;background:transparent;color:var(--muted);font-size:12px;font-weight:600;padding:7px 12px;cursor:pointer;font-family:inherit}
  .iv-theme button.is-active{background:var(--brand);color:#fff}

  .iv-toggle{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--muted);font-weight:600;cursor:pointer}
  .iv-kpis-scope{font-size:12px;color:var(--muted);margin:0 0 8px}
  .iv-kpis-scope strong{color:var(--text)}
  .iv-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:18px}
  .iv-kpi{display:flex;flex-direction:column;gap:3px;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:13px 15px}
  .iv-kpi-lab{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);font-weight:600}
  .iv-kpi-val{font-size:22px;font-weight:750;font-variant-numeric:tabular-nums}
  .iv-kpi-sub{font-size:11px;color:var(--muted)}

  .iv-office{background:var(--panel);border:1px solid var(--line);border-radius:14px;margin-bottom:12px;overflow:hidden}
  .iv-office>summary{display:flex;align-items:center;gap:14px;padding:14px 16px;cursor:pointer;list-style:none}
  .iv-office>summary::-webkit-details-marker{display:none}
  .iv-chev{color:var(--muted);transition:transform .15s;font-size:15px}
  details[open]>summary .iv-chev{transform:rotate(90deg)}
  .iv-office-name{font-weight:750;font-size:15px;flex:1}
  .iv-mini{display:flex;gap:16px}
  /* Audited-progress bar shown at every nesting level (office/branch/invoice/category). */
  .iv-bar{display:inline-flex;align-items:center;width:74px;height:6px;border-radius:999px;background:var(--line);overflow:hidden;flex:none;margin-left:10px}
  .iv-office>summary .iv-bar,.iv-branch>summary .iv-bar{width:90px}
  .iv-bar-fill{display:block;height:100%;width:0;background:var(--brand);border-radius:999px;transition:width .2s}
  .iv-bar.is-complete .iv-bar-fill{background:var(--green)}
  .iv-cat>summary .iv-bar{margin-left:8px}
  .iv-mini div{text-align:center}
  .iv-mini strong{display:block;font-size:15px;font-weight:750;font-variant-numeric:tabular-nums}
  .iv-mini span{font-size:10px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted)}
  .iv-office-body{padding:4px 12px 12px;border-top:1px solid var(--line)}

  .iv-branch{border:1px solid var(--line);border-radius:11px;margin:10px 0;background:var(--panel2)}
  .iv-branch>summary{display:flex;align-items:center;gap:12px;padding:11px 13px;cursor:pointer;list-style:none;flex-wrap:wrap}
  .iv-branch>summary::-webkit-details-marker{display:none}
  .iv-branch-name{font-weight:700;font-size:13.5px}
  .iv-branch-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap}
  .iv-branch-body{padding:4px 12px 12px}

  .iv-inv{border:1px solid var(--line);border-radius:10px;margin:8px 0;background:var(--panel)}
  .iv-inv>summary{display:flex;align-items:center;gap:12px;padding:10px 12px;cursor:pointer;list-style:none;flex-wrap:wrap}
  .iv-inv>summary::-webkit-details-marker{display:none}
  .iv-inv-no{font-weight:700;font-size:13px}
  .iv-inv-sub{color:var(--muted);font-size:11.5px}
  .iv-inv-id{display:inline-flex;align-items:baseline;gap:6px;flex-wrap:wrap}
  /* Row action buttons (Price List + Invoice) — left-justified, identical pill formatting */
  .iv-rowbtns{display:inline-flex;gap:6px;align-items:center;flex-wrap:wrap}
  .iv-rowbtn{display:inline-flex;align-items:center;gap:4px;border:1px solid var(--line);border-radius:999px;padding:3px 12px;font-size:12px;font-weight:650;color:var(--brand);text-decoration:none;background:var(--panel);white-space:nowrap}
  .iv-rowbtn:hover{border-color:var(--brand);background:var(--brand-bg)}
  .iv-rowbtn.is-disabled{color:var(--muted);background:var(--panel2);border-color:var(--line);opacity:.55;cursor:not-allowed;pointer-events:none}
  .iv-inv-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .iv-inv-body{padding:4px 12px 12px;border-top:1px solid var(--line)}

  /* roof-system category sections (collapsible, default-collapsed) */
  .iv-cats{margin-top:6px}
  .iv-cat{border:1px solid var(--line);border-radius:8px;margin:6px 0;background:var(--panel2)}
  .iv-cat>summary{display:flex;align-items:center;gap:10px;padding:8px 11px;cursor:pointer;list-style:none}
  .iv-cat>summary::-webkit-details-marker{display:none}
  .iv-cat>summary b{font-size:12.5px}
  .iv-cat-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .iv-cat-sub{font-variant-numeric:tabular-nums;font-weight:650;font-size:12px;color:var(--muted)}
  .iv-cat .iv-table{margin:0 8px 8px}
  /* In "to-audit only" mode, hide categories with nothing pending */
  .iv-pending-only .iv-cat[data-pend="0"]{display:none}

  .iv-table{width:100%;border-collapse:collapse;margin-top:6px}
  .iv-table thead th{font-size:10px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted);text-align:left;padding:8px 9px;border-bottom:1px solid var(--line);background:var(--panel2);white-space:nowrap}
  .iv-table td{padding:7px 9px;border-bottom:1px solid var(--line);font-size:12.5px}
  .iv-table td.num{text-align:right;font-variant-numeric:tabular-nums}
  .iv-ln{cursor:pointer}
  .iv-ln:hover{background:var(--brand-bg)}
  .iv-ln.sel{background:var(--brand-bg)}
  .iv-sku{font-family:ui-monospace,Menlo,monospace;font-size:11.5px}

  .iv-disp{margin-top:10px;padding:12px;background:var(--panel2);border-radius:9px}
  .iv-disp-lead{font-size:12.5px;color:var(--muted);margin-bottom:10px}
  .iv-disp-lead b{color:var(--ink)}
  .iv-disp-tabs{display:flex;gap:8px;margin-bottom:10px}
  .iv-disp-tabs button{appearance:none;border:1px solid var(--line);border-radius:8px;background:var(--panel);color:var(--muted);font-size:12px;font-weight:700;padding:6px 10px;cursor:pointer}
  .iv-disp-tabs button.is-active{background:var(--brand);color:#fff;border-color:var(--brand)}
  .iv-disp-panel.is-hidden{display:none}
  .iv-grid2{display:grid;grid-template-columns:1fr 1fr;gap:9px}
  .iv-grp{grid-column:1/-1;font-size:10.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);font-weight:700;margin-top:2px}
  .iv-act{text-align:left;border:1px solid var(--line);border-radius:10px;background:var(--panel);padding:10px 12px;cursor:pointer;font-family:inherit;color:inherit}
  .iv-act:hover{border-color:var(--brand)}
  .iv-act .t{font-weight:650;font-size:12px;display:block}
  .iv-act .h{color:var(--muted);font-size:11px;margin-top:3px;line-height:1.35;display:block}
  .iv-act.accept .t{color:var(--green)}
  .iv-act.credit{grid-column:1/-1;border-color:color-mix(in srgb, var(--red) 35%, var(--line))}
  .iv-act.credit .t{color:var(--red)}
  .iv-act.chosen{border-color:var(--brand);background:var(--brand-bg)}
  .iv-preview-head{display:flex;justify-content:space-between;gap:8px;flex-wrap:wrap;margin-bottom:8px}
  .iv-msg-muted{font-size:11px;color:var(--muted)}
  .iv-preview-validation{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
  .iv-msg-grid{display:grid;grid-template-columns:1fr;gap:10px}
  .iv-msg-card{border:1px solid var(--line);border-radius:10px;background:var(--panel);padding:10px}
  .iv-msg-card header{display:flex;align-items:center;gap:8px;margin-bottom:8px}
  .iv-msg-row{font-size:12px;margin-bottom:7px}
  .iv-msg-body{font-size:12px;border:1px solid var(--line);border-radius:8px;background:var(--panel2);padding:8px}
  .iv-msg-body p{margin:0 0 8px}
  .iv-msg-body p:last-child{margin-bottom:0}
  .iv-msg-errors{display:flex;gap:6px;flex-wrap:wrap}
  .iv-attachments{margin:6px 0 0 16px}
  .iv-exec-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
  .iv-exec{appearance:none;border:1px solid var(--line);border-radius:8px;padding:8px 10px;background:var(--panel);font-size:12px;font-weight:700;cursor:pointer}
  .iv-exec.approve{color:var(--green);border-color:color-mix(in srgb, var(--green) 35%, var(--line))}
  .iv-exec.edit{color:var(--brand)}
  .iv-exec.reject{color:var(--red);border-color:color-mix(in srgb, var(--red) 35%, var(--line))}
  .iv-exec.delete{color:var(--muted)}

  .iv-modal{position:fixed;inset:0;background:rgba(11,17,25,.55);display:flex;align-items:center;justify-content:center;z-index:90;padding:16px}
  .iv-modal-card{width:min(760px,100%);max-height:80vh;overflow:auto;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:14px;box-shadow:var(--shadow)}
  .iv-modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
  .iv-modal-close{appearance:none;border:1px solid var(--line);background:var(--panel2);border-radius:8px;padding:2px 9px;font-size:18px;cursor:pointer;color:var(--muted)}
  .iv-wysiwyg-tools{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px}
  .iv-wysiwyg-tools button{appearance:none;border:1px solid var(--line);background:var(--panel2);color:var(--ink);border-radius:8px;padding:6px 9px;font-size:12px;cursor:pointer}
  .iv-wysiwyg{border:1px solid var(--line);border-radius:10px;min-height:180px;padding:10px;font-size:13px;background:var(--panel2)}
  .iv-modal-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:10px}
  .iv-modal-btn{appearance:none;border:1px solid var(--line);background:var(--panel2);color:var(--ink);border-radius:8px;padding:7px 10px;font-size:12px;cursor:pointer;font-weight:700}
  .iv-modal-btn-primary{background:var(--brand);border-color:var(--brand);color:#fff}

  .ia-toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:#1c2733;color:#fff;padding:11px 18px;border-radius:10px;font-size:13px;opacity:0;pointer-events:none;transition:.2s;z-index:60;box-shadow:0 10px 30px rgba(0,0,0,.25)}
  .ia-toast.show{opacity:1}

  .iv-audited{color:var(--green);font-weight:650}
  .iv-mark{appearance:none;border:1px solid var(--green);background:var(--green-bg);color:var(--green);border-radius:6px;padding:3px 9px;font-size:11px;font-weight:650;cursor:pointer;font-family:inherit}
  .iv-mark:hover{filter:brightness(.96)}
  .iv-ln.is-audited{opacity:.62}
  .iv.iv-pending-only .iv-ln.is-audited{display:none}
  .iv-audit-cell{white-space:nowrap}
  .iv-job{color:var(--brand);font-weight:600}
  @media (max-width:1100px){ .iv-kpis{grid-template-columns:repeat(2,1fr)} }
</style>

<script src="/src/scripts/invoice-audit-tree.ts"></script>
