---
import AppShell from "../layouts/AppShell.astro";
import { loadPriceAgreementAudit } from "@lib/price-agreement-audit";

const data = await loadPriceAgreementAudit();
const generatedAt = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" }).format(new Date(data.generatedAt));
const runtimeTone = data.status === "live" ? "ready" : "watch";
const runtimeLabel = data.status === "live" ? "Supabase live" : "Supabase pending";
const offices = data.offices.map((o) => o.office);
const pct = (n: number) => Math.round(n * 100) + "%";
const payload = JSON.stringify({ offices: data.offices }).replace(/</g, "\\u003c");
---

<AppShell title="Price Agreement Audit" eyebrow="Accounting" activePage="pricing">
  <section class="pa" data-theme="light" data-pref="system">
    <div class="pa-toolbar">
      <input class="pa-input" id="pa-search" type="search" placeholder="Search branch, agreement, item…" autocomplete="off" />
      <select class="pa-select" id="pa-office">
        <option value="">All PE offices</option>
        {offices.map((o) => <option value={o}>{o}</option>)}
      </select>
      <select class="pa-select" id="pa-filter">
        <option value="">All branches</option>
        <option value="needs">Needs renewal</option>
        <option value="expired">Expired</option>
        <option value="expiring">Expiring ≤30d</option>
        <option value="active">Active (covered)</option>
        <option value="api">API · non-negotiated</option>
      </select>
      <span class="pa-spacer"></span>
      <span class="runtime-pill" data-tone={runtimeTone}><span class="signal-dot" aria-hidden="true"></span>{runtimeLabel}</span>
      <span class="pa-count">{generatedAt}</span>
      <div class="pa-theme" role="group" aria-label="Theme">
        <button type="button" data-set-theme="system" class="is-active">System</button>
        <button type="button" data-set-theme="light">Light</button>
        <button type="button" data-set-theme="dark">Dark</button>
      </div>
    </div>

    <div class="pa-kpis">
      <div class="pa-kpi"><span class="pa-kpi-lab">API Coverage</span><span class="pa-kpi-val">{pct(data.totals.apiCoveragePct)}</span><span class="pa-kpi-sub">{Math.round(data.totals.apiCoveragePct * data.totals.gpaItems)}/{data.totals.gpaItems} GPA items with a live API price</span></div>
      <div class="pa-kpi"><span class="pa-kpi-lab">Negotiated</span><span class="pa-kpi-val">{pct(data.totals.negotiatedPct)}</span><span class="pa-kpi-sub">{Math.round(data.totals.negotiatedPct * data.totals.gpaItems)}/{data.totals.gpaItems} GPA items with a negotiated price</span></div>
      <div class="pa-kpi"><span class="pa-kpi-lab">Agreements Expired</span><span class="pa-kpi-val">{data.totals.expired}</span><span class="pa-kpi-sub">branches with a lapsed agreement</span></div>
      <div class="pa-kpi"><span class="pa-kpi-lab">Agreements Expiring ≤30d</span><span class="pa-kpi-val">{data.totals.expiring}</span><span class="pa-kpi-sub">renew before lapse</span></div>
      <div class="pa-kpi"><span class="pa-kpi-lab">Avg Variance %</span><span class="pa-kpi-val">{data.totals.avgVariancePct == null ? "—" : data.totals.avgVariancePct.toFixed(1) + "%"}</span><span class="pa-kpi-sub">negotiated vs API price</span></div>
    </div>

    {data.offices.length === 0 && <p class="pa-empty">No price agreements found in the live pipeline.</p>}
    <div id="pa-tree"></div>
  </section>

  <script type="application/json" id="pa-data" set:html={payload}></script>
  <div class="ia-toast" id="pa-toast" role="status" aria-live="polite"></div>
</AppShell>

<style is:global>
  .pa{
    --bg:#f4f6f9; --panel:#fff; --panel2:#f7f8fb; --ink:#1c2733; --muted:#6b7886; --line:#e3e8ef;
    --brand:#5b46d8; --brand-bg:#efecfd; --green:#137a4d; --green-bg:#e3f5ec; --yellow:#946400; --yellow-bg:#fbf0d4;
    --orange:#a4480d; --orange-bg:#fbe7d6; --red:#a51f1f; --red-bg:#fbe2e2; --grey:#5a6573; --grey-bg:#eceff4; --shadow:0 6px 18px rgba(20,28,40,.08);
    background:var(--bg); color:var(--ink);
    margin:calc(-1 * var(--space-4,16px)) calc(-1 * var(--gutter,24px)) calc(-1 * var(--space-6,24px));
    padding:18px var(--gutter,24px) 30px; min-height:70vh; font-family:var(--font-sans,Inter,system-ui,sans-serif);
  }
  .pa[data-theme="dark"]{
    --bg:#0f141b; --panel:#161d27; --panel2:#1c2530; --ink:#e6edf5; --muted:#8b98a8; --line:#27313e;
    --brand:#8a7bff; --brand-bg:#21243f; --green:#7ee2ad; --green-bg:#123626; --yellow:#f2cf6b; --yellow-bg:#3a3115;
    --orange:#f3a766; --orange-bg:#3d2913; --red:#ff8585; --red-bg:#3d1a1a; --grey:#9aa6b4; --grey-bg:#222c38; --shadow:0 6px 18px rgba(0,0,0,.4);
  }
  .pa .pill{display:inline-block;padding:2px 9px;border-radius:999px;font-size:11px;font-weight:600;white-space:nowrap;line-height:1.5}
  .pa .pill-green{background:var(--green-bg);color:var(--green)} .pa .pill-yellow{background:var(--yellow-bg);color:var(--yellow)}
  .pa .pill-orange{background:var(--orange-bg);color:var(--orange)} .pa .pill-red{background:var(--red-bg);color:var(--red)}
  .pa .pill-grey{background:var(--grey-bg);color:var(--grey)} .pa .pill-brand{background:var(--brand-bg);color:var(--brand)}
  .pa .pa-pill-agreement{background:rgba(147,112,219,.16);color:#9370db;font-weight:650;text-decoration:none;cursor:pointer}
  .pa a.pa-pill-agreement:hover{background:rgba(147,112,219,.28)} .pa .pa-pill-agreement.is-nopdf{opacity:.7;cursor:default}
  .pa .pa-dash{color:var(--muted)} .pa .pa-var-ok{color:#2e9e5b} .pa .pa-var-mid{color:#d08a1d} .pa .pa-var-hi{color:#d0494b}

  .pa-toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px}
  .pa-input,.pa-select{background:var(--panel);border:1px solid var(--line);color:var(--ink);border-radius:8px;padding:8px 11px;font-size:13px;font-family:inherit}
  .pa-input{min-width:240px} .pa-spacer{flex:1} .pa-count{font-size:12px;color:var(--muted)} .pa-empty{color:var(--muted);padding:14px 4px}
  .pa-theme{display:inline-flex;border:1px solid var(--line);border-radius:9px;overflow:hidden;background:var(--panel)}
  .pa-theme button{appearance:none;border:none;background:transparent;color:var(--muted);font-size:12px;font-weight:600;padding:7px 12px;cursor:pointer;font-family:inherit}
  .pa-theme button.is-active{background:var(--brand);color:#fff}

  .pa-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:18px}
  .pa-kpi{display:flex;flex-direction:column;gap:3px;background:var(--panel);border:1px solid var(--line);border-radius:14px;padding:13px 15px}
  .pa-kpi-lab{font-size:11px;text-transform:uppercase;letter-spacing:.04em;color:var(--muted);font-weight:600}
  .pa-kpi-val{font-size:22px;font-weight:750;font-variant-numeric:tabular-nums}
  .pa-kpi-sub{font-size:11px;color:var(--muted)}

  .pa-office{background:var(--panel);border:1px solid var(--line);border-radius:14px;margin-bottom:12px;overflow:hidden}
  .pa-office>summary{display:flex;align-items:center;gap:14px;padding:14px 16px;cursor:pointer;list-style:none}
  .pa-office>summary::-webkit-details-marker{display:none}
  .pa-chev{color:var(--muted);transition:transform .15s;font-size:15px}
  details[open]>summary .pa-chev{transform:rotate(90deg)}
  .pa-office-name{font-weight:750;font-size:15px;flex:1}
  .pa-mini{display:flex;gap:16px}
  .pa-mini div{text-align:center}
  .pa-mini strong{display:block;font-size:15px;font-weight:750;font-variant-numeric:tabular-nums}
  .pa-mini span{font-size:10px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted)}
  .pa-office-body{padding:4px 12px 12px;border-top:1px solid var(--line)}

  .pa-branch{border:1px solid var(--line);border-radius:11px;margin:10px 0;background:var(--panel2)}
  .pa-branch>summary{display:flex;align-items:center;gap:12px;padding:11px 13px;cursor:pointer;list-style:none;flex-wrap:wrap}
  .pa-branch>summary::-webkit-details-marker{display:none}
  .pa-branch-id{display:inline-flex;align-items:baseline;gap:6px}
  .pa-branch-name{font-weight:700;font-size:13.5px}
  .pa-sub{color:var(--muted);font-size:11.5px}
  .pa-branch-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .pa-branch-body{padding:4px 8px 10px}
  .pa-renew{appearance:none;border:1px solid var(--brand);background:var(--brand-bg);color:var(--brand);border-radius:7px;padding:4px 10px;font-size:11px;font-weight:650;cursor:pointer;font-family:inherit;white-space:nowrap}
  .pa-renew:hover{filter:brightness(.97)}

  .pa-cats{margin-top:6px}
  .pa-disp-lead{font-size:12.5px;color:var(--muted);padding:8px 6px}
  .pa-cat{border:1px solid var(--line);border-radius:8px;margin:6px 0;background:var(--panel)}
  .pa-cat>summary{display:flex;align-items:center;gap:10px;padding:8px 11px;cursor:pointer;list-style:none}
  .pa-cat>summary::-webkit-details-marker{display:none}
  .pa-cat>summary b{font-size:12.5px}
  .pa-cat-tags{margin-left:auto;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
  .pa-itable{width:100%;border-collapse:collapse;margin:0 8px 8px}
  .pa-itable thead th{font-size:10px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted);text-align:left;padding:8px 9px;border-bottom:1px solid var(--line);background:var(--panel2);white-space:nowrap}
  .pa-itable td{padding:7px 9px;border-bottom:1px solid var(--line);font-size:12.5px}
  .pa-itable td.num{text-align:right;font-variant-numeric:tabular-nums}
  .pa-sku{font-family:ui-monospace,Menlo,monospace;font-size:11.5px}

  .ia-toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:#1c2733;color:#fff;padding:11px 18px;border-radius:10px;font-size:13px;opacity:0;pointer-events:none;transition:.2s;z-index:60;box-shadow:0 10px 30px rgba(0,0,0,.25)}
  .ia-toast.show{opacity:1}
  @media (max-width:1100px){ .pa-kpis{grid-template-columns:repeat(2,1fr)} .pa-mini{gap:10px} }
</style>

<script src="/src/scripts/price-agreement-tree.ts"></script>
