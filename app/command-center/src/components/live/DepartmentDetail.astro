---
import AppShell from "../../layouts/AppShell.astro";
import LiveMetricGrid from "./LiveMetricGrid.astro";
import LiveWorkQueue from "./LiveWorkQueue.astro";
import type { LiveDepartmentSurface } from "@lib/live-work";

interface Props {
  surface: LiveDepartmentSurface;
  routePath: string;
  routeTitle: string;
  routeDescription?: string;
}

const { surface, routePath, routeTitle, routeDescription } = Astro.props;
const normalizedRoute = routePath.split("?")[0];
const items = surface.items.filter((item) => item.href.split("?")[0] === normalizedRoute || item.href.startsWith(`${normalizedRoute}?`));
const visibleItems = items.length > 0 ? items : surface.items;
const generatedAt = new Intl.DateTimeFormat("en-US", {
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
  month: "short",
}).format(new Date(surface.generatedAt));
const tone = surface.status === "live" ? "ready" : surface.status === "degraded" ? "watch" : "blocked";
---

<AppShell title={routeTitle} eyebrow={`${surface.title} Detail`} activePage={surface.department} surface={surface}>
  <section class="live-department-hero" aria-label={`${routeTitle} detail summary`}>
    <div class="surface-heading">
      <div>
        <p class="eyebrow">{surface.primaryHuman} Workspace</p>
        <h2>{routeDescription ?? surface.subtitle}</h2>
      </div>
      <div class="surface-meta">
        <span class="runtime-pill" data-tone={tone}>
          <span class="signal-dot" aria-hidden="true"></span>
          {surface.status}
        </span>
        <span>{generatedAt}</span>
      </div>
    </div>

    <p class="live-source-summary">
      {items.length > 0
        ? `${items.length} live item${items.length === 1 ? "" : "s"} matched this route.`
        : `No item is pinned to this exact route right now, so the department queue is shown for context.`}
      {" "}
      Source contract: {surface.sourceSummary}
    </p>

    {
      surface.errors.length > 0 && (
        <div class="accounting-boundary-notice">
          <strong>Live data issue</strong>
          <span>{surface.errors.join(" ")}</span>
        </div>
      )
    }

    <LiveMetricGrid metrics={surface.metrics} />
  </section>

  <LiveWorkQueue items={visibleItems} emptyLabel="No source-backed work is open for this filtered route." />

  <script src="/src/scripts/command-center.ts"></script>
</AppShell>
