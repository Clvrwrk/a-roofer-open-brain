---
import { formatNumber } from "@lib/accounting-dashboard";
import type { VendorTerritorySurface } from "@lib/vendor-territories";
import BoundaryNotice from "./BoundaryNotice.astro";

interface Props {
  surface: VendorTerritorySurface;
  mapsBrowserKey: string;
}

const { surface, mapsBrowserKey } = Astro.props;
const payloadJson = JSON.stringify(surface).replace(/</g, "\\u003c");
const selectedBranch = surface.reviewBranches[0] ?? surface.branches[0] ?? null;
const selectedOffice = selectedBranch?.assignedOfficeId
  ? surface.offices.find((office) => office.id === selectedBranch.assignedOfficeId)
  : surface.offices[0] ?? null;
const sourceLabel = surface.source === "snapshot" ? "previous app snapshot" : surface.source;
---

<section
  class="vendor-map-workspace"
  data-vendor-territory-app
  data-maps-key={mapsBrowserKey}
  aria-label="Vendor territory map"
>
  <script type="application/json" id="vendor-territories-payload" set:html={payloadJson}></script>

  <header class="vendor-map-header">
    <div>
      <p class="eyebrow">Vendor Territories</p>
      <h2>PE office coverage and vendor branch pricing</h2>
    </div>
    <div class="vendor-map-header-actions">
      <span class="runtime-pill" data-tone={surface.status === "live" ? "ready" : "watch"}>
        <span class="signal-dot" aria-hidden="true"></span>
        {sourceLabel}
      </span>
      <span class="runtime-pill" data-tone={mapsBrowserKey ? "ready" : "watch"}>
        <span class="signal-dot" aria-hidden="true"></span>
        Google Maps
      </span>
    </div>
  </header>

  {
    surface.errors.length > 0 && (
      <BoundaryNotice
        title="Map data degraded"
        detail={surface.errors.join(" ")}
        action="Use the map for orientation, then refresh live Supabase data before final territory decisions."
      />
    )
  }

  <div class="vendor-map-toolbar" aria-label="Vendor map filters">
    <label>
      <span>Vendor</span>
      <select id="vt-vendor-filter">
        <option value="all">All vendors</option>
        {surface.vendors.map((vendor) => (
          <option value={vendor.slug}>{vendor.name}{vendor.isPlanned ? " · planned" : ""}</option>
        ))}
      </select>
    </label>
    <label>
      <span>State</span>
      <select id="vt-state-filter">
        <option value="all">Full US</option>
        {surface.states.map((state) => <option value={state}>{state}</option>)}
      </select>
    </label>
    <label>
      <span>Status</span>
      <select id="vt-status-filter">
        <option value="all">All status</option>
        <option value="needs_office_route">Needs PE route</option>
        <option value="missing_branch_pricing">Missing pricing</option>
        <option value="vendor_brand">Healthy</option>
        <option value="overlap_pending">Overlap</option>
        <option value="out_of_boundary">Out of boundary</option>
        <option value="unclassified">Unclassified</option>
      </select>
    </label>
    <label>
      <span>Color by</span>
      <select id="vt-color-lens">
        <option value="coverage">Price Coverage</option>
        <option value="invoice">Invoice Audit</option>
        <option value="composite">Composite</option>
      </select>
    </label>
    <label class="vendor-map-search-label">
      <span>Search</span>
      <input id="vt-search" type="search" placeholder="Branch, city, state" autocomplete="off" />
    </label>
    <div class="vendor-map-button-group">
      <button type="button" class="inline-action" data-vt-action="fit-us">US</button>
      <button type="button" class="inline-action" data-vt-action="fit-selection">Fit</button>
    </div>
  </div>

  <div class="vendor-map-shell">
    <div class="vendor-map-canvas-column">
      <div id="vendor-territory-google-map" class="vendor-google-map" role="application" aria-label="Google Map of PE offices and vendor branches"></div>
      <div class="vendor-map-legend" aria-label="Marker legend">
        <span><i style="background:#16a34a"></i>Healthy</span>
        <span><i style="background:#eab308"></i>Needs attention</span>
        <span><i style="background:#dc2626"></i>Problem</span>
        <span><i style="background:#64748b"></i>Out of scope</span>
        <span><i class="office-legend-mark"></i>PE office</span>
      </div>
    </div>

    <aside class="vendor-map-detail-panel" id="vendor-territory-detail-panel" aria-live="polite">
      {
        selectedBranch ? (
          <>
            <p class="eyebrow">{selectedBranch.vendorName}</p>
            <h3>{selectedBranch.branchNumber ? `${selectedBranch.branchNumber} / ` : ""}{selectedBranch.branchName}</h3>
            <div class="vendor-detail-chip-row">
              <span class={`territory-status status-${selectedBranch.pricingStatus}`}>{selectedBranch.pricingStatus.replace("_", " ")}</span>
              <span class={`territory-marker-chip marker-${selectedBranch.markerPriority}`}>{selectedBranch.markerPriority.replaceAll("_", " ")}</span>
            </div>
            <dl class="vendor-detail-list">
              <div><dt>Address</dt><dd>{[selectedBranch.address, selectedBranch.city, selectedBranch.state].filter(Boolean).join(", ") || "Missing"}</dd></div>
              <div><dt>Assigned office</dt><dd>{selectedBranch.assignedOfficeName ?? "Unassigned"}</dd></div>
              <div><dt>Suggested office</dt><dd>{selectedBranch.suggestedOfficeName ?? "No suggestion"}</dd></div>
              <div><dt>Pricing source</dt><dd>{selectedBranch.priceEvidenceLabel}</dd></div>
              <div><dt>Price rows</dt><dd>{selectedBranch.pricingWaterfall.itemCount} lines / {selectedBranch.pricingWaterfall.uniqueSkuCount} SKUs</dd></div>
            </dl>
          </>
        ) : selectedOffice ? (
          <>
            <p class="eyebrow">PE Office</p>
            <h3>{selectedOffice.name}</h3>
            <dl class="vendor-detail-list">
              <div><dt>Address</dt><dd>{[selectedOffice.address, selectedOffice.city, selectedOffice.state].filter(Boolean).join(", ") || "Missing"}</dd></div>
              <div><dt>Region</dt><dd>{selectedOffice.regionName ?? selectedOffice.regionCode ?? "Unmapped"}</dd></div>
              <div><dt>Branches</dt><dd>{formatNumber(selectedOffice.branchCounts.total)}</dd></div>
            </dl>
          </>
        ) : (
          <>
            <p class="eyebrow">Vendor Territories</p>
            <h3>No branch selected</h3>
          </>
        )
      }
    </aside>
  </div>


  <script is:inline>
    (() => {
      const root = document.querySelector("[data-vendor-territory-app]");
      if (!root) return;

      const payloadScript = document.getElementById("vendor-territories-payload");
      const payload = JSON.parse(payloadScript?.textContent || "{}");
      const mapsKey = root.dataset.mapsKey || "";
      const mapEl = document.getElementById("vendor-territory-google-map");
      const detailPanel = document.getElementById("vendor-territory-detail-panel");
      const vendorFilter = document.getElementById("vt-vendor-filter");
      const stateFilter = document.getElementById("vt-state-filter");
      const statusFilter = document.getElementById("vt-status-filter");
      const searchInput = document.getElementById("vt-search");
      const countEls = {
        branches: root.querySelector('[data-vt-count="branches"]'),
        offices: root.querySelector('[data-vt-count="offices"]'),
        needsOfficeRoute: root.querySelector('[data-vt-count="needsOfficeRoute"]'),
        missingBranchPricing: root.querySelector('[data-vt-count="missingBranchPricing"]'),
        vendorBrand: root.querySelector('[data-vt-count="vendorBrand"]'),
        missingCoordinates: root.querySelector('[data-vt-count="missingCoordinates"]'),
      };

      const state = {
        map: null,
        infoWindow: null,
        branchMarkers: [],
        officeMarkers: [],
        clusterMarkers: [],
        polygons: [],
        selectedBranchId: null, // load-time default = Richardson, TX office, not a branch
      };

      const officeById = new Map((payload.offices || []).map((office) => [office.id, office]));
      const vendorBySlug = new Map((payload.vendors || []).map((vendor) => [vendor.slug, vendor]));
      const colorLensSelect = document.getElementById("vt-color-lens");

      // --- Color lens: one map, three ways to read "where the issues are" ---
      const LENS_GREEN = "#16a34a";
      const LENS_YELLOW = "#eab308";
      const LENS_RED = "#dc2626";
      const LENS_GREY = "#64748b";

      function inDriveTime(branch) {
        // Within a PE office 2-hour isochrone (covered/overlap) = in scope.
        return branch.pricingStatus === "covered" || branch.pricingStatus === "overlap_pending";
      }

      function isNegotiated(branch) {
        return Boolean(branch.currentAgreement);
      }

      function lensColor(branch) {
        const lens = colorLensSelect?.value || "coverage";
        if (lens === "invoice") {
          if (branch.invoiceGateStatus === "approved") return LENS_GREEN;
          return LENS_RED;
        }
        if (lens === "composite") {
          if (!inDriveTime(branch)) return LENS_GREY;
          const issues =
            (isNegotiated(branch) ? 0 : 1) + (branch.invoiceGateStatus === "approved" ? 0 : 1);
          if (issues === 0) return LENS_GREEN;
          if (issues === 1) return LENS_YELLOW;
          return LENS_RED;
        }
        // coverage (default)
        if (!inDriveTime(branch)) return LENS_GREY;
        if (isNegotiated(branch)) return LENS_GREEN;
        if (branch.pricingWaterfall && branch.pricingWaterfall.itemCount > 0) return LENS_YELLOW;
        return LENS_RED;
      }

      // --- Branch / office popups (InfoWindow KPI card + quick links) ---
      function kpiCell(label, value, tone) {
        return `<div class="vmpop-kpi${tone ? ` tone-${tone}` : ""}"><strong>${value}</strong><span>${escapeHtml(label)}</span></div>`;
      }

      function linkRow(href, label, soon, blank) {
        if (soon) return `<span class="vmpop-link is-soon">${escapeHtml(label)}<small>soon</small></span>`;
        const t = blank ? ` target="_blank" rel="noopener"` : "";
        return `<a class="vmpop-link" href="${escapeHtml(href)}"${t}>${escapeHtml(label)}<span aria-hidden="true">${blank ? "↗" : "→"}</span></a>`;
      }

      function branchPopupHtml(branch) {
        const scope = inDriveTime(branch);
        const negotiated = isNegotiated(branch);
        const gateApproved = branch.invoiceGateStatus === "approved";
        // When a price agreement is on file, the second chip becomes the PA number and a
        // third chip carries its expiry date (flagged red when lapsed) — replacing the
        // generic "covered" status chip. Includes expired agreements on purpose.
        const agreement = branch.agreementOnFile || branch.currentAgreement;
        let agreementChips;
        if (agreement && agreement.agreementNumber) {
          let expiryChip = "";
          if (agreement.expiryDate) {
            const expired = new Date(`${agreement.expiryDate}T00:00:00`) < new Date(new Date().toDateString());
            expiryChip = `<span class="vmpop-chip ${expired ? "chip-expired" : "chip-muted"}">${expired ? "Expired" : "Expires"} ${escapeHtml(agreement.expiryDate)}</span>`;
          }
          agreementChips = `<span class="vmpop-chip chip-pa">PA ${escapeHtml(agreement.agreementNumber)}</span>${expiryChip}`;
        } else {
          agreementChips = `<span class="vmpop-chip chip-status">${escapeHtml(statusText(branch.pricingStatus))}</span>`;
        }
        const branchParam = branch.branchNumber ? `?branch=${encodeURIComponent(branch.branchNumber)}` : "";
        const waterfall = branch.pricingWaterfall || { itemCount: 0, uniqueSkuCount: 0 };

        const kpis = [
          kpiCell("Negotiated", negotiated ? "Yes" : "No", negotiated ? "ok" : "bad"),
          kpiCell("Price lines", numberText(waterfall.itemCount || 0), waterfall.itemCount ? "" : "warn"),
          kpiCell("Invoice gate", gateApproved ? "OK" : "Blocked", gateApproved ? "ok" : "bad"),
        ].join("");

        const links = [
          branch.branchNumber ? linkRow(`/accounting/price-list/branch${branchParam}`, "Active Price List", false, true) : "",
          linkRow(`/accounting/invoice-audit${branchParam}`, "Invoice Audit"),
          linkRow(`/abc-price-agreement-gaps`, "Price Agreement Audit"),
          scope ? linkRow(`/accounting/vendor-regions`, "Price List Coverage") : "",
          linkRow("", "Proposal / Estimate", true),
        ]
          .filter(Boolean)
          .join("");

        let contact = "";
        if (scope) {
          const rows = [];
          if (branch.phone) rows.push(`<a href="tel:${escapeHtml(branch.phone)}">Call branch · ${escapeHtml(branch.phone)}</a>`);
          if (branch.managerName || branch.managerEmail) {
            const mgr = escapeHtml(branch.managerName || "Branch manager");
            rows.push(
              branch.managerEmail
                ? `<a href="mailto:${escapeHtml(branch.managerEmail)}">Email ${mgr}</a>`
                : `<span>${mgr}</span>`,
            );
          }
          rows.push(
            branch.salesRepName
              ? `<span>Sales rep · ${escapeHtml(branch.salesRepName)} <small>(email soon)</small></span>`
              : `<span class="vmpop-muted">Sales rep contact — to be added</span>`,
          );
          contact = `<div class="vmpop-contact"><p class="vmpop-section">Fleet / branch contact</p>${rows.join("")}</div>`;
        } else {
          contact = `<p class="vmpop-muted">Outside 2-hour drive time — not in active scope.</p>`;
        }

        return `
          <div class="vmpop">
            <p class="vmpop-eyebrow">${escapeHtml(branch.vendorName)}</p>
            <h4 class="vmpop-title">${escapeHtml(branch.branchNumber ? `${branch.branchNumber} · ${branch.branchName}` : branch.branchName)}</h4>
            <div class="vmpop-chips">
              <span class="vmpop-chip ${scope ? "chip-ok" : "chip-muted"}">${scope ? "In drive time" : "Out of scope"}</span>
              ${agreementChips}
            </div>
            <div class="vmpop-kpis">${kpis}</div>
            ${contact}
            <div class="vmpop-links"><p class="vmpop-section">Go to</p>${links}</div>
          </div>
        `;
      }

      function officePopupHtml(office) {
        const counts = office.branchCounts || { total: 0, needsOfficeRoute: 0, missingPricing: 0, healthy: 0 };
        // Carry the office NAME so the target dashboards land pre-filtered.
        const officeParam = `?office=${encodeURIComponent(office.name)}`;
        const kpis = [
          kpiCell("Branches", numberText(counts.total), ""),
          kpiCell("Healthy", numberText(counts.healthy), counts.healthy ? "ok" : ""),
          kpiCell("Missing pricing", numberText(counts.missingPricing), counts.missingPricing ? "bad" : "ok"),
        ].join("");
        const links = [
          linkRow(`/accounting/vendor-regions${officeParam}`, "Price List Coverage"),
          linkRow(`/accounting/invoice-audit${officeParam}`, "Invoice Audit"),
          linkRow("", "Proposal / Estimate", true),
        ].join("");
        return `
          <div class="vmpop">
            <p class="vmpop-eyebrow">PE Office</p>
            <h4 class="vmpop-title">${escapeHtml(office.name)}</h4>
            <div class="vmpop-chips">
              <span class="vmpop-chip chip-ok">${escapeHtml(office.driveTimeMinutes || 120)} min drive time</span>
              <span class="vmpop-chip chip-status">${escapeHtml(office.regionName || office.regionCode || "Unmapped")}</span>
            </div>
            <div class="vmpop-kpis">${kpis}</div>
            <div class="vmpop-links"><p class="vmpop-section">Go to</p>${links}</div>
          </div>
        `;
      }

      function openBranchPopup(branch, marker) {
        if (!state.infoWindow) return;
        state.infoWindow.setContent(branchPopupHtml(branch));
        state.infoWindow.open({ anchor: marker, map: state.map });
      }

      function openOfficePopup(office, marker) {
        if (!state.infoWindow) return;
        state.infoWindow.setContent(officePopupHtml(office));
        state.infoWindow.open({ anchor: marker, map: state.map });
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function numberText(value) {
        return new Intl.NumberFormat("en-US").format(Number(value || 0));
      }

      function statusText(value) {
        return String(value || "").replaceAll("_", " ");
      }

      function locationText(item) {
        return [item.address, item.city, item.state].filter(Boolean).join(", ") || [item.city, item.state].filter(Boolean).join(", ") || "Missing";
      }

      function loadMapsApi() {
        return new Promise((resolve, reject) => {
          if (window.google?.maps) {
            resolve();
            return;
          }
          if (!mapsKey) {
            reject(new Error("missing-key"));
            return;
          }
          const callbackName = "__vendorTerritoryMapsReady";
          window[callbackName] = () => {
            delete window[callbackName];
            resolve();
          };
          const script = document.createElement("script");
          script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(mapsKey)}&v=weekly&loading=async&callback=${callbackName}`;
          script.async = true;
          script.onerror = () => reject(new Error("maps-load-failed"));
          document.head.appendChild(script);
        });
      }

      function branchIcon(branch, scale = 6) {
        return {
          path: google.maps.SymbolPath.CIRCLE,
          fillColor: lensColor(branch),
          fillOpacity: 0.96,
          strokeColor: branch.markerPriority === "needs_office_route" ? "#78350f" : "#ffffff",
          strokeOpacity: 1,
          strokeWeight: branch.markerPriority === "vendor_brand" ? 1.8 : 2.6,
          scale,
        };
      }

      function officeIcon() {
        return {
          path: "M -7 6 L 0 -8 L 7 6 Z",
          fillColor: "#11133f",
          fillOpacity: 1,
          strokeColor: "#ffffff",
          strokeWeight: 2,
          scale: 1.55,
        };
      }

      function clusterIcon(size) {
        const large = size >= 50;
        return {
          path: google.maps.SymbolPath.CIRCLE,
          fillColor: "#11133f",
          fillOpacity: 0.92,
          strokeColor: "#ffffff",
          strokeWeight: 3,
          scale: large ? 18 : size >= 20 ? 15 : 12,
        };
      }

      function clearMarkers(markers) {
        markers.forEach((marker) => marker.setMap(null));
        markers.length = 0;
      }

      function visibleBranches() {
        const vendor = vendorFilter.value;
        const selectedState = stateFilter.value;
        const selectedStatus = statusFilter.value;
        const query = searchInput.value.trim().toLowerCase();

        return (payload.branches || []).filter((branch) => {
          if (branch.latitude === null || branch.longitude === null) return false;
          if (vendor !== "all" && branch.vendorSlug !== vendor) return false;
          if (selectedState !== "all" && branch.state !== selectedState) return false;
          if (selectedStatus !== "all") {
            const priorityHit = branch.markerPriority === selectedStatus;
            const statusHit = branch.pricingStatus === selectedStatus;
            if (!priorityHit && !statusHit) return false;
          }
          if (!query) return true;
          const haystack = [
            branch.vendorName,
            branch.branchNumber,
            branch.branchName,
            branch.address,
            branch.city,
            branch.state,
            branch.assignedOfficeName,
            branch.suggestedOfficeName,
          ]
            .filter(Boolean)
            .join(" ")
            .toLowerCase();
          return haystack.includes(query);
        });
      }

      function visibleOffices() {
        const selectedState = stateFilter.value;
        return (payload.offices || []).filter((office) => {
          if (office.latitude === null || office.longitude === null) return false;
          return selectedState === "all" || office.state === selectedState;
        });
      }

      function clusterCellSize(zoom) {
        if (zoom <= 4) return 6;
        if (zoom <= 5) return 3;
        if (zoom <= 6) return 1.5;
        if (zoom <= 7) return 0.75;
        return 0.35;
      }

      function groupedBranches(branches) {
        const zoom = state.map?.getZoom() || 4;
        if (zoom >= 8) return branches.map((branch) => ({ branches: [branch] }));
        const cell = clusterCellSize(zoom);
        const groups = new Map();
        branches.forEach((branch) => {
          const key = `${Math.floor(branch.latitude / cell)}:${Math.floor(branch.longitude / cell)}`;
          const group = groups.get(key) || [];
          group.push(branch);
          groups.set(key, group);
        });
        return [...groups.values()].map((branches) => ({ branches }));
      }

      function renderCounts(branches) {
        const counts = {
          branches: branches.length,
          offices: visibleOffices().length,
          needsOfficeRoute: branches.filter((branch) => branch.markerPriority === "needs_office_route").length,
          missingBranchPricing: branches.filter((branch) => branch.markerPriority === "missing_branch_pricing").length,
          vendorBrand: branches.filter((branch) => branch.markerPriority === "vendor_brand").length,
          missingCoordinates: (payload.branches || []).filter((branch) => branch.latitude === null || branch.longitude === null).length,
        };

        Object.entries(counts).forEach(([key, value]) => {
          if (countEls[key]) countEls[key].textContent = numberText(value);
        });
      }

      function renderOfficeLayers() {
        const selectedState = stateFilter.value;
        state.polygons.forEach((polygon) => polygon.setMap(null));
        state.polygons = [];
        clearMarkers(state.officeMarkers);

        visibleOffices().forEach((office) => {
          if (office.boundary?.coordinates?.[0]?.length && (selectedState === "all" || office.state === selectedState)) {
            const polygon = new google.maps.Polygon({
              paths: office.boundary.coordinates[0].map((point) => ({ lat: point[1], lng: point[0] })),
              strokeColor: "#11133f",
              strokeOpacity: 0.58,
              strokeWeight: 1.4,
              fillColor: "#0f766e",
              fillOpacity: 0.07,
              map: state.map,
            });
            polygon.addListener("click", () => renderOfficeDetail(office));
            state.polygons.push(polygon);
          }

          const marker = new google.maps.Marker({
            position: { lat: office.latitude, lng: office.longitude },
            map: state.map,
            title: office.name,
            icon: officeIcon(),
            zIndex: 1000,
          });
          marker.addListener("click", () => {
            renderOfficeDetail(office);
            openOfficePopup(office, marker);
            state.map.panTo(marker.getPosition());
          });
          state.officeMarkers.push(marker);
        });
      }

      function renderBranches() {
        const branches = visibleBranches();
        renderCounts(branches);
        clearMarkers(state.branchMarkers);
        clearMarkers(state.clusterMarkers);

        groupedBranches(branches).forEach((group) => {
          if (group.branches.length === 1) {
            const branch = group.branches[0];
            const marker = new google.maps.Marker({
              position: { lat: branch.latitude, lng: branch.longitude },
              map: state.map,
              title: `${branch.vendorName} / ${branch.branchNumber || ""} ${branch.branchName}`,
              icon: branchIcon(branch, branch.markerPriority === "needs_office_route" ? 7.5 : 6.2),
              zIndex: branch.markerPriority === "needs_office_route" ? 750 : branch.markerPriority === "missing_branch_pricing" ? 700 : 500,
            });
            marker.addListener("click", () => {
              state.selectedBranchId = branch.id;
              renderBranchDetail(branch);
              openBranchPopup(branch, marker);
              state.map.panTo(marker.getPosition());
            });
            state.branchMarkers.push(marker);
            return;
          }

          const lat = group.branches.reduce((sum, branch) => sum + branch.latitude, 0) / group.branches.length;
          const lng = group.branches.reduce((sum, branch) => sum + branch.longitude, 0) / group.branches.length;
          const urgentCount = group.branches.filter((branch) => branch.markerPriority !== "vendor_brand").length;
          const marker = new google.maps.Marker({
            position: { lat, lng },
            map: state.map,
            title: `${group.branches.length} vendor branches`,
            icon: clusterIcon(group.branches.length),
            label: {
              text: String(group.branches.length),
              color: "#ffffff",
              fontSize: "12px",
              fontWeight: "800",
            },
            zIndex: urgentCount ? 650 : 450,
          });
          marker.addListener("click", () => {
            state.map.panTo(marker.getPosition());
            state.map.setZoom(Math.min((state.map.getZoom() || 4) + 2, 10));
          });
          state.clusterMarkers.push(marker);
        });

        // Only render branch detail when a branch was explicitly selected;
        // the load-time default is the Richardson, TX office (set in init()).
        const selected = state.selectedBranchId ? branches.find((branch) => branch.id === state.selectedBranchId) : null;
        const plannedVendor = vendorFilter.value !== "all" ? vendorBySlug.get(vendorFilter.value) : null;
        if (selected) renderBranchDetail(selected);
        else if (plannedVendor?.isPlanned) renderPlannedVendorDetail(plannedVendor);
      }

      function fitTo(items) {
        const bounds = new google.maps.LatLngBounds();
        items.forEach((item) => {
          if (item.latitude !== null && item.longitude !== null) bounds.extend({ lat: item.latitude, lng: item.longitude });
        });
        if (!bounds.isEmpty()) state.map.fitBounds(bounds, 44);
      }

      function fitUnitedStates() {
        const bounds = new google.maps.LatLngBounds(
          { lat: 24.3, lng: -125.1 },
          { lat: 49.6, lng: -66.8 },
        );
        state.map.fitBounds(bounds, 18);
      }

      function renderBranchDetail(branch) {
        // Side card = the popup card + the PE-office assignment picker. The popup
        // (on the pin) stays compact; the rail card lets you register the
        // branch↔office choice (persisted with who + when via the assign API).
        const candidates = (branch.candidateOffices && branch.candidateOffices.length
          ? branch.candidateOffices
          : (payload.offices || []).map((o) => ({ id: o.id, name: o.name, driveMinutes: null, isSuggested: o.id === branch.suggestedOfficeId })));
        const options = candidates
          .map((c) => {
            const mins = c.driveMinutes != null ? ` · ${Math.round(c.driveMinutes)} min` : "";
            const sel = c.id === (branch.assignedOfficeId || branch.suggestedOfficeId) ? " selected" : "";
            return `<option value="${escapeHtml(c.id)}"${sel}>${escapeHtml(c.name)}${mins}${c.isSuggested ? " · suggested" : ""}</option>`;
          })
          .join("");
        const decided = branch.territoryDecidedAt
          ? `Set by ${escapeHtml(branch.territoryDecidedBy || "—")} on ${escapeHtml(new Date(branch.territoryDecidedAt).toLocaleDateString())}`
          : "Not yet assigned";
        const assignBox = `
          <div class="vmpop-assign">
            <p class="vmpop-section">PE office for this branch</p>
            <p class="vmpop-assign-now">${escapeHtml(branch.assignedOfficeName || "Unassigned")} <span class="vmpop-muted-inline">· ${decided}</span></p>
            <select class="vmpop-select" data-office-select>${options}</select>
            <button type="button" class="vmpop-save" data-assign-branch="${escapeHtml(branch.id)}">Save office choice</button>
            <p class="vmpop-assign-status" data-assignment-status></p>
          </div>`;
        detailPanel.innerHTML = branchPopupHtml(branch) + assignBox;
        detailPanel.querySelector("[data-assign-branch]")?.addEventListener("click", () => saveAssignment(branch));
      }

      function renderOfficeDetail(office) {
        detailPanel.innerHTML = officePopupHtml(office);
      }

      function renderPlannedVendorDetail(vendor) {
        detailPanel.innerHTML = `
          <p class="eyebrow">Planned vendor</p>
          <h3>${escapeHtml(vendor.name)}</h3>
          <dl class="vendor-detail-list">
            <div><dt>Status</dt><dd>API not connected yet</dd></div>
            <div><dt>Workflow</dt><dd>Mirror table, canonical branch reconciliation, weekly pull</dd></div>
          </dl>
        `;
      }

      async function saveAssignment(branch) {
        const select = detailPanel.querySelector("[data-office-select]");
        const statusEl = detailPanel.querySelector("[data-assignment-status]");
        const officeId = select?.value;
        if (!officeId) return;

        const button = detailPanel.querySelector("[data-assign-branch]");
        button.disabled = true;
        if (statusEl) statusEl.textContent = "Saving...";

        try {
          const response = await fetch("/api/vendor-territories/assign", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ vendorBranchId: branch.id, officeId }),
          });
          const result = await response.json();
          if (!response.ok || !result.ok) throw new Error(result.error_description || result.error || "assignment failed");
          const index = payload.branches.findIndex((item) => item.id === branch.id);
          if (index >= 0 && result.branch) payload.branches[index] = result.branch;
          const updated = result.branch || payload.branches[index] || branch;
          state.selectedBranchId = updated.id;
          renderBranches();
          renderBranchDetail(updated);
        } catch (error) {
          if (statusEl) statusEl.textContent = error instanceof Error ? error.message : "Assignment failed";
          button.disabled = false;
        }
      }

      function bindControls() {
        [vendorFilter, stateFilter, statusFilter, searchInput, colorLensSelect].forEach((control) => {
          control?.addEventListener("input", () => {
            renderOfficeLayers();
            renderBranches();
          });
        });

        // Beneficial filter behaviors: narrowing by state/vendor/search auto-fits
        // the map to what's now visible; clearing back to "all" returns to the US.
        [stateFilter, vendorFilter, searchInput].forEach((control) => {
          control?.addEventListener("change", () => {
            if (stateFilter.value === "all" && vendorFilter.value === "all" && !searchInput.value.trim()) {
              fitUnitedStates();
            } else {
              fitTo([...visibleOffices(), ...visibleBranches()]);
            }
          });
        });

        root.querySelector('[data-vt-action="fit-us"]')?.addEventListener("click", () => {
          fitUnitedStates();
        });
        root.querySelector('[data-vt-action="fit-selection"]')?.addEventListener("click", () => {
          fitTo([...visibleOffices(), ...visibleBranches()]);
        });
      }

      async function init() {
        if (!mapEl) return;
        try {
          await loadMapsApi();
        } catch (error) {
          mapEl.innerHTML = `<div class="vendor-map-empty"><strong>Google Maps unavailable</strong><span>${error?.message === "missing-key" ? "GOOGLE_MAPS_BROWSER_KEY is not configured." : "Maps JavaScript failed to load for this origin."}</span></div>`;
          return;
        }

        state.map = new google.maps.Map(mapEl, {
          center: { lat: 39.4, lng: -98.35 },
          zoom: 4,
          minZoom: 3,
          mapTypeControl: true,
          streetViewControl: false,
          fullscreenControl: true,
          clickableIcons: false,
          styles: [{ featureType: "poi", stylers: [{ visibility: "off" }] }],
        });
        state.infoWindow = new google.maps.InfoWindow();
        bindControls();
        renderOfficeLayers();
        renderBranches();
        state.map.addListener("zoom_changed", renderBranches);
        state.map.addListener("idle", () => {
          if (!state.branchMarkers.length && !state.clusterMarkers.length) renderBranches();
        });

        // Default selection: Richardson, TX PE office (not the first branch).
        const defaultOffice = (payload.offices || []).find((o) => /richardson/i.test(o.name || ""));
        if (defaultOffice && defaultOffice.latitude != null && defaultOffice.longitude != null) {
          renderOfficeDetail(defaultOffice);
          state.map.setCenter({ lat: defaultOffice.latitude, lng: defaultOffice.longitude });
          state.map.setZoom(8);
        } else {
          fitUnitedStates();
        }
      }

      if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", init);
      else init();
    })();
  </script>
</section>
