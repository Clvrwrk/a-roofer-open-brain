---
interface Props {
  label: string;
  value: string;
  caption: string;
  href: string;
  tone?: "critical" | "review" | "ready" | "info";
}

const { label, value, caption, href, tone = "info" } = Astro.props;
---

<a class="accounting-metric-card" data-tone={tone} href={href}>
  <span>{label}</span>
  <strong>{value}</strong>
  <small>{caption}</small>
</a>
