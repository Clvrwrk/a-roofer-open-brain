config/roofer.config.yaml

# OS / editor
.DS_Store

# Local agent workspaces and raw import staging
.worktrees/
imports/
private/

# Local raw archive buckets: keep only manifests in Git
archive/local-uncommitted-*/*
!archive/local-uncommitted-*/MANIFEST.md

# MemSearch local runtime state
.memsearch/
context/transcripts/*
!context/transcripts/.gitkeep

# Dashboard build output
deployment/remote/dashboard/dist/

# Command Center local build output
app/command-center/.astro/
app/command-center/dist/

# Orgo local desktop registry output
deployment/remote/orgo/pro-exteriors-orgo-desktops.json

# Supabase local/link state
supabase/.temp/
supabase/.branches/

# Sandbox API smoke outputs
integrations/bridges/abc-supply/.sandbox-runs/
integrations/bridges/abc-supply/.production-runs/
integrations/bridges/abc-supply/.mirror-runs/

# Node
node_modules/

# Scratch / log / byproduct files (kept out of history; trip branch-switch guard otherwise)
*.log
t.txt
time.txt
probe-time.txt
.playwright-mcp/
outputs/
.claude/launch.json
