# Secrets — never commit
.env
.env.*
!.env.example

# Client config holds live company data (see config/.env.example for secret names)
config/roofer.config.yaml

# OS / editor
.DS_Store

# Local agent workspaces and raw import staging
.worktrees/
.hermes/
imports/
private/

# Local raw archive buckets: keep only manifests in Git
archive/local-uncommitted-*/*
!archive/local-uncommitted-*/MANIFEST.md

# MemSearch local runtime state
.memsearch/
context/transcripts/*
!context/transcripts/.gitkeep

# Dashboard build output
deployment/remote/dashboard/dist/

# Command Center local build output
app/command-center/.astro/
app/command-center/dist/

# Orgo local desktop registry output
deployment/remote/orgo/pro-exteriors-orgo-desktops.json

# Supabase local/link state
supabase/.temp/
supabase/.branches/

# Sandbox API smoke outputs
integrations/bridges/abc-supply/.sandbox-runs/
integrations/bridges/abc-supply/.production-runs/
integrations/bridges/abc-supply/.mirror-runs/

# Node
node_modules/

# Scratch / log / byproduct files (kept out of history; trip branch-switch guard otherwise)
*.log
t.txt
time.txt
probe-time.txt
.playwright-mcp/
outputs/
.claude/launch.json
# Editor/sync duplicate copies, e.g. "excalidraw 2.log", "workspace 2.json"
* 2.*

# Local working data / client data buckets (may contain PII — keep out of history)
Estimate Tool - Working Files/
supabase/Accounting Files/
supabase/Price Agreements/
# Map screenshot artifacts at repo root
vendor-territory-map-*.png

# Claude local (machine-specific permissions)
.claude/settings.local.json
integrations/bridges/abc-supply/.price-seed-runs/

# Python build output
__pycache__/
*.pyc

# StormWatch live-run scratch (raw replay SQL/JSON — regenerated per run, never committed)
tmp_stormwatch_*

# Open Engine (DevTeam plane) runtime byproducts — context SKILL.md files ARE tracked,
# but smoke tests / claimed-task working files / local ledger state are regenerated per run
agents/dev-engine/**/smoke-test*.txt
agents/dev-engine/**/*.local.*
agents/dev-engine/**/.runtime/
