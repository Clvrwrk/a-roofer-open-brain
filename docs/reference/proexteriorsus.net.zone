$ORIGIN proexteriorsus.net.
$TTL 600

agentmail._domainkey.agentmail	IN	TXT	"v=DKIM1; k=rsa; "
mail.agentmail	IN	TXT	"v=spf1 include:amazonses.com -all"
_dmarc.agentmail	IN	TXT	"v=DMARC1; p=reject; rua=mailto:dmarc@agentmail.proexteriorsus.net"

agentmail	IN	MX	10 inbound-smtp.us-east-1.amazonaws.com.
mail.agentmail	IN	MX	10 feedback-smtp.us-east-1.amazonses.com.

