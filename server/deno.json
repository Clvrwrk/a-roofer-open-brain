{
  "$comment": "Deno config for the a-roofers-open-brain MCP server (MCP containers on Hetzner runtime is Deno).",
  "tasks": {
    "serve": "deno run --allow-net --allow-env index.ts",
    "check": "deno check index.ts functions/*.ts",
    "test": "deno test --allow-none tests/"
  },
  "imports": {
    "std/": "https://deno.land/std@0.224.0/"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  }
}
